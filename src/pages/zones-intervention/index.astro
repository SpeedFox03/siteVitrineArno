---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import QuoteSection from '../../components/QuoteSection.astro';
import Footer from '../../components/Footer.astro';
import { zones } from '../../data/zones';

const base = import.meta.env.BASE_URL;
const zonesLiege = zones.filter((z) => z.region === 'liege');
const zonesNamurCondroz = zones.filter((z) => z.region === 'namur-condroz');
---

<BaseLayout
  title="Zones d'intervention | Peintre à Neupré, Liège, Namur & Condroz — Moment D.Art"
  description="Moment D.Art, entreprise de peinture basée à Neupré, intervient dans toute la région liégeoise (Liège, Sprimont, Embourg, Beaufays) ainsi qu'à Namur, Ciney, Dinant et dans le Condroz."
>
  <Header />

  <Breadcrumb items={[
    { label: 'Accueil', href: base },
    { label: "Zones d'intervention" },
  ]} />

  <section class="page-hero">
    <div class="container">
      <div class="card hero-card">
        <span class="eyebrow">Où nous travaillons</span>
        <h1>Zones d'intervention</h1>
        <p class="lead">
          Moment D.Art est basé à Neupré, en province de Liège. C'est de là que partent tous nos chantiers : nous intervenons au quotidien dans la région liégeoise, et nous nous déplaçons à Namur, dans le Condroz et autour de Ciney et Dinant selon la nature des projets.
        </p>
      </div>
    </div>
  </section>

  <section class="section zones-block">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Région liégeoise</span>
        <h2>Autour de notre siège de Neupré</h2>
      </div>
      <div class="zones-grid">
        {zonesLiege.map((z) =>
          z.slug ? (
            <a class="card zone-card zone-card-link" href={`${base}zones-intervention/${z.slug}`}>
              <h3>{z.nom}</h3>
              <p>{z.resume}</p>
              <span class="zone-more">Peintre à {z.nom} →</span>
            </a>
          ) : (
            <div class="card zone-card">
              <h3>{z.nom}</h3>
              <p>{z.resume}</p>
            </div>
          )
        )}
      </div>
    </div>
  </section>

  <section class="section section-alt zones-block">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Namur & Condroz</span>
        <h2>Nos déplacements vers Namur, Ciney et Dinant</h2>
      </div>
      <div class="zones-grid">
        {zonesNamurCondroz.map((z) =>
          z.slug ? (
            <a class="card zone-card zone-card-link" href={`${base}zones-intervention/${z.slug}`}>
              <h3>{z.nom}</h3>
              <p>{z.resume}</p>
              <span class="zone-more">Peintre à {z.nom} →</span>
            </a>
          ) : (
            <div class="card zone-card">
              <h3>{z.nom}</h3>
              <p>{z.resume}</p>
            </div>
          )
        )}
      </div>
    </div>
  </section>

  <section class="section orga-section">
    <div class="container">
      <div class="grid-2 orga-grid">
        <div>
          <span class="eyebrow">En pratique</span>
          <h2>Comment nous organisons un chantier hors région liégeoise</h2>
        </div>
        <div class="orga-text">
          <p>
            Pour les projets à Namur, Ciney, Dinant ou ailleurs dans le Condroz, tout commence comme pour n'importe quel chantier : une demande via le <a href={`${base}devis`}>formulaire de devis</a>, si possible accompagnée de photos. Cela nous permet de préparer la visite sur place et, souvent, de proposer une première projection visuelle du résultat.
          </p>
          <p style="margin-top:1.1rem;">
            Les visites et les interventions dans ces zones sont regroupées pour rester efficaces : les délais sont annoncés clairement dès le devis, et le déroulement du chantier est identique partout — protection des lieux, préparation des supports, finitions soignées et nettoyage quotidien. Découvrez nos <a href={`${base}services`}>services</a> et nos <a href={`${base}realisations`}>réalisations</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <QuoteSection />
  <Footer />
</BaseLayout>

<style>
  .hero-card {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .section-alt {
    background: linear-gradient(180deg, rgba(240, 233, 223, 0.55), rgba(246, 242, 235, 0));
  }

  .zones-block {
    padding-top: 3.5rem;
    padding-bottom: 3.5rem;
  }

  .zones-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .zone-card {
    padding: 1.6rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .zone-card h3 {
    font-size: 1.15rem;
    color: var(--text);
  }

  .zone-card p {
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .zone-card-link {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .zone-card-link:hover {
    transform: translateY(-3px);
    box-shadow: 0 28px 64px rgba(36, 29, 23, 0.12);
  }

  .zone-more {
    margin-top: auto;
    padding-top: 0.5rem;
    font-size: 0.84rem;
    font-weight: 700;
    color: #7A5C3E;
  }

  .orga-section {
    padding-top: 3.5rem;
  }

  .orga-grid {
    gap: 3rem;
    align-items: start;
  }

  .orga-text a {
    color: #7A5C3E;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .orga-text a:hover {
    color: #3E2C1C;
  }

  @media (max-width: 1000px) {
    .zones-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .zones-grid {
      grid-template-columns: 1fr;
    }

    .hero-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
