---
interface Props {
  title: string;
  description: string;
  meta: string;
  beforeLabel?: string;
  afterLabel?: string;
  beforeImage: string;
  afterImage: string;
  frame?: 'landscape' | 'portrait';
  axis?: 'horizontal' | 'vertical';
  blurSides?: boolean;
}

const props = Astro.props;
const {
  title,
  meta,
  beforeLabel = 'Avant',
  afterLabel = 'Après',
  beforeImage,
  afterImage,
} = props;

const frame = props.frame ?? 'landscape';
const blurSides = props.blurSides ?? true;
const axis = props.axis ?? (frame === 'portrait' ? 'vertical' : 'horizontal');
const overlayClip = axis === 'vertical'
  ? 'clip-path: inset(0 0 50% 0);'
  : 'clip-path: inset(0 50% 0 0);';
const beforeLabelClip = axis === 'vertical'
  ? 'clip-path: inset(50% 0 0 0);'
  : 'clip-path: inset(0 0 0 50%);';
const dividerPosition = axis === 'vertical' ? 'top: 50%;' : 'left: 50%;';
const sliderStyle = (frame === 'portrait' && blurSides)
  ? `--blur-before: url("${beforeImage}"); --blur-after: url("${afterImage}");`
  : undefined;
---

<article class={`showcase card frame-${frame} axis-${axis}`}>
  <div class="showcase-head">
    <div>
      <p class="meta">{meta}</p>
      <h3>{title}</h3>
    </div>
  </div>

  <div class="ba-slider" data-ba-slider data-axis={axis} style={sliderStyle}>
    <img src={afterImage} alt={`${title} - ${afterLabel}`} class="base-image" loading="lazy" />

    <div class="overlay" style={overlayClip}>
      <img src={beforeImage} alt={`${title} - ${beforeLabel}`} class="overlay-image" loading="lazy" />
      <span class="label label-before">{beforeLabel}</span>
    </div>

    <div class="before-label-layer" style={beforeLabelClip}>
      <span class="label label-after">{afterLabel}</span>
    </div>

    <input aria-label={`Comparer ${beforeLabel} et ${afterLabel}`} aria-orientation={axis === 'vertical' ? 'vertical' : 'horizontal'} type="range" min="0" max="100" value="50" />

    <div class="divider" style={dividerPosition}>
      <div class="handle">
        <svg class="handle-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M8 12H16M8 12L5 9M8 12L5 15M16 12L19 9M16 12L19 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </div>
</article>

<style>
  .showcase {
    padding: 1rem;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 1rem;
    height: 100%;
    background: var(--surface-strong);
    position: relative;
    overflow: hidden;
  }

  .showcase::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.22), rgba(255,255,255,0.03) 40%, transparent 65%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .showcase:hover::before {
    opacity: 1;
  }

  .showcase-head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-items: start;
  }

  .showcase-head > div,
  .showcase-head > p {
    margin: 0;
  }

  .showcase-head h3 {
    margin: 0;
  }

  .meta {
    margin-bottom: 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--accent);
  }

  .ba-slider {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    isolation: isolate;
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #ece4d8;
    border: 1px solid rgba(23,22,20,0.08);
  }

  .ba-slider::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(18,13,8,0.04), transparent 30%, rgba(18,13,8,0.12));
    pointer-events: none;
    z-index: 4;
  }

  /* Blurred background for portrait images in landscape frame */
  .frame-portrait .ba-slider::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--blur-after);
    background-size: cover;
    background-position: center;
    filter: blur(22px);
    transform: scale(1.12);
    z-index: 0;
    pointer-events: none;
  }

  .frame-portrait .overlay::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--blur-before);
    background-size: cover;
    background-position: center;
    filter: blur(22px);
    transform: scale(1.12);
    z-index: 0;
    pointer-events: none;
  }

  .ba-slider img {
    user-select: none;
    pointer-events: none;
  }

  .base-image,
  .overlay-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  /* Portrait images fill height, blur fills sides */
  .frame-portrait .base-image,
  .frame-portrait .overlay-image {
    object-fit: contain;
  }

  .base-image {
    filter: saturate(0.95) contrast(1.02);
  }

  .overlay {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 2;
  }

  .before-label-layer {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 2;
    pointer-events: none;
  }

  .overlay::after {
    content: '';
    position: absolute;
    background: rgba(255,255,255,0.85);
    pointer-events: none;
    z-index: 3;
  }

  .axis-horizontal .overlay::after {
    top: 0;
    bottom: 0;
    right: 0;
    width: 1px;
  }

  .axis-vertical .overlay::after {
    left: 0;
    right: 0;
    bottom: 0;
    height: 1px;
  }

  .overlay-image {
    filter: grayscale(0.18) saturate(0.7) brightness(0.96);
  }

  .label {
    position: absolute;
    bottom: 1rem;
    pointer-events: none;
    z-index: 2;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.42rem 0.85rem;
    border-radius: 999px;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(23,22,20,0.08);
    box-shadow: 0 6px 16px rgba(23,22,20,0.12);
  }

  .label-before {
    left: 1rem;
    background: rgba(36,29,23,0.72);
    color: rgba(255,255,255,0.92);
  }

  .label-after {
    right: 1rem;
    background: var(--accent);
    color: #faf7f2;
  }

  .axis-vertical .label-before {
    top: 1rem;
    bottom: auto;
  }

  .ba-slider input[type='range'] {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    margin: 0;
    z-index: 3;
    /* laisse le scroll vertical de la page passer ; les gestes horizontaux pilotent le slider */
    touch-action: pan-y;
  }

  .axis-horizontal .ba-slider input[type='range'] {
    cursor: ew-resize;
  }

  .axis-vertical .ba-slider input[type='range'] {
    writing-mode: vertical-lr;
    cursor: ns-resize;
  }

  .divider {
    position: absolute;
    pointer-events: none;
    z-index: 3;
  }

  .axis-horizontal .divider {
    top: 0;
    bottom: 0;
    width: 0;
  }

  .axis-vertical .divider {
    left: 0;
    right: 0;
    height: 0;
  }

  .divider::before {
    content: '';
    position: absolute;
    background: rgba(255,255,255,0.95);
    box-shadow: 0 0 0 1px rgba(23,22,20,0.08);
  }

  .axis-horizontal .divider::before {
    top: 0;
    bottom: 0;
    left: 0;
    width: 1px;
  }

  .axis-vertical .divider::before {
    left: 0;
    right: 0;
    top: 0;
    height: 1px;
  }

  .handle {
    position: absolute;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 4px 20px rgba(23,22,20,0.22), 0 1px 4px rgba(23,22,20,0.10);
    border: 1.5px solid rgba(23,22,20,0.10);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .axis-horizontal .handle {
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .axis-vertical .handle {
    left: 50%;
    top: 0;
    transform: translate(-50%, -50%);
  }

  .handle-icon {
    width: 22px;
    height: 22px;
    color: var(--text);
  }

  .axis-vertical .handle-icon {
    transform: rotate(90deg);
  }

  @media (max-width: 860px) {
    .showcase {
      padding: 0.9rem;
      gap: 0.85rem;
    }

    .showcase-head {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .ba-slider {
      border-radius: 20px;
    }

    .label {
      font-size: 0.68rem;
      padding: 0.38rem 0.7rem;
    }

    .label-before { left: 0.8rem; }
    .label-after  { right: 0.8rem; }

    .handle {
      width: 46px;
      height: 46px;
    }
  }

  @media (max-width: 560px) {
    .showcase {
      padding: 0.8rem;
      gap: 0.75rem;
      border-radius: 22px;
    }

    .meta {
      font-size: 0.68rem;
      margin-bottom: 0.3rem;
    }

    .showcase-head h3 {
      font-size: 1.05rem;
      line-height: 1.15;
    }

    .ba-slider {
      border-radius: 18px;
      aspect-ratio: 4 / 3;
    }

    .label {
      font-size: 0.62rem;
      padding: 0.32rem 0.6rem;
      bottom: 0.7rem;
    }

    .label-before { left: 0.7rem; }
    .label-after  { right: 0.7rem; }

    .handle {
      width: 42px;
      height: 42px;
    }

    .handle-icon {
      width: 18px;
      height: 18px;
    }

  }
</style>

<script>
  document.querySelectorAll('[data-ba-slider]').forEach((slider) => {
    const input = slider.querySelector<HTMLInputElement>('input');
    const overlay = slider.querySelector<HTMLElement>('.overlay');
    const beforeLabelLayer = slider.querySelector<HTMLElement>('.before-label-layer');
    const divider = slider.querySelector<HTMLElement>('.divider');
    const axis = slider.getAttribute('data-axis') === 'vertical' ? 'vertical' : 'horizontal';

    if (!input || !overlay || !beforeLabelLayer || !divider) return;

    const clamp = (value: number) => Math.min(100, Math.max(0, value));

    const apply = (value: number) => {
      const v = clamp(value);
      input.value = String(v);
      if (axis === 'vertical') {
        overlay.style.clipPath = `inset(0 0 ${100 - v}% 0)`;
        beforeLabelLayer.style.clipPath = `inset(${v}% 0 0 0)`;
        (divider as HTMLElement).style.top = `${v}%`;
      } else {
        overlay.style.clipPath = `inset(0 ${100 - v}% 0 0)`;
        beforeLabelLayer.style.clipPath = `inset(0 0 0 ${v}%)`;
        (divider as HTMLElement).style.left = `${v}%`;
      }
    };

    const valueFromPointer = (event: PointerEvent) => {
      const rect = (slider as HTMLElement).getBoundingClientRect();
      const raw = axis === 'vertical'
        ? ((event.clientY - rect.top) / rect.height) * 100
        : ((event.clientX - rect.left) / rect.width) * 100;
      return Math.round(clamp(raw));
    };

    const el = slider as HTMLElement;
    let dragging = false;
    let decided = false;       // toucher : a-t-on tranché entre drag et scroll ?
    let startX = 0;
    let startY = 0;
    const THRESHOLD = 6;       // px avant de décider de l'intention

    // Keyboard support via native input (only when not dragging)
    input.addEventListener('input', () => {
      if (!dragging) apply(Number(input.value));
    });

    el.addEventListener('pointerdown', (e) => {
      const pe = e as PointerEvent;
      startX = pe.clientX;
      startY = pe.clientY;

      if (pe.pointerType === 'touch') {
        // on attend le 1er mouvement pour distinguer drag (axe slider) et scroll (en travers)
        decided = false;
        dragging = false;
      } else {
        decided = true;
        dragging = true;
        el.setPointerCapture(pe.pointerId);
        apply(valueFromPointer(pe));
      }
    });

    el.addEventListener('pointermove', (e) => {
      const pe = e as PointerEvent;

      if (pe.pointerType === 'touch' && !decided) {
        const dx = pe.clientX - startX;
        const dy = pe.clientY - startY;
        if (Math.abs(dx) < THRESHOLD && Math.abs(dy) < THRESHOLD) return;

        const alongAxis = axis === 'vertical'
          ? Math.abs(dy) > Math.abs(dx)
          : Math.abs(dx) > Math.abs(dy);

        decided = true;
        if (alongAxis) {
          dragging = true;
          el.setPointerCapture(pe.pointerId);
          apply(valueFromPointer(pe));
        }
        // sinon : geste en travers -> on laisse le navigateur scroller la page
        return;
      }

      if (!dragging) return;
      apply(valueFromPointer(pe));
    });

    el.addEventListener('pointerup', (e) => {
      const pe = e as PointerEvent;
      // tap simple (toucher sans glissement) : on positionne le curseur
      if (pe.pointerType === 'touch' && !decided) {
        apply(valueFromPointer(pe));
      }
      dragging = false;
      decided = false;
    });

    el.addEventListener('pointercancel', () => {
      dragging = false;
      decided = false;
    });

    apply(50);
  });
</script>
