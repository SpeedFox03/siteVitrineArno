---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import ServicesOverview from '../../components/ServicesOverview.astro';
import QuoteSection from '../../components/QuoteSection.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Services de nettoyage — Moment D.Art"
  description="Services de nettoyage et entretien de bâtiments : nettoyage intérieur, extérieur, surfaces techniques, sols, murs et éléments spécifiques."
>
  <Header />

  <section class="page-hero">
    <div class="container">
      <div class="card hero-card">
        <span class="eyebrow">Services</span>
        <h1>Des interventions dédiées au nettoyage et à l’entretien des bâtiments.</h1>
        <p class="lead">
          Chaque intervention est orientée vers le nettoyage, la remise en état et l’entretien des surfaces,
          que ce soit pour des espaces privés, des bâtiments professionnels ou des zones techniques.
        </p>
      </div>
    </div>
  </section>

  <ServicesOverview />
  <QuoteSection />
  <Footer />
</BaseLayout>

<style>
  .hero-card {
    padding: 1.7rem;
  }

  .hero-card h1 {
    max-width: 12ch;
    margin: 0.85rem 0 1rem;
  }
</style>