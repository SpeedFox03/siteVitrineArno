---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Nettoyage intérieur — Moment D.Art"
  description="Nettoyage intérieur de murs, plafonds, cages d’escalier et espaces de vie. Entretien, remise en état et nettoyage de surfaces intérieures."
>
  <Header />

  <section class="page-hero">
    <div class="container">
      <div class="card grid-2">
        <div>
          <span class="eyebrow">Service</span>
          <h1>Nettoyage intérieur</h1>
          <p class="lead">
            Nettoyage de murs, plafonds, cages d’escalier et espaces de vie pour maintenir des surfaces propres, saines et entretenues.
          </p>
        </div>

        <img
          src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1400&q=80"
          alt="Nettoyage intérieur"
          style="border-radius:22px; width:100%; height:100%; object-fit:cover; min-height:320px;"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        <div>
          <h2>Pour quels besoins ?</h2>
          <p class="lead">
            Entretien courant, nettoyage approfondi, remise en état après occupation, préparation d’un bien avant location, vente ou réouverture.
          </p>
        </div>

        <div class="card" style="padding:1.5rem;">
          <h3>Interventions possibles</h3>
          <p>
            Dépoussiérage, nettoyage de surfaces, élimination des traces, lavage de zones intérieures et remise en état générale des espaces.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>