---
// Grille de TOUS les services, utilisée sur les pages zones (/zones-intervention/<ville>).
// S'appuie sur les styles partagés .zp-* (le contenu des pages zones est dans .zp-scope).
import { servicesListe } from '../data/services';

interface Props {
  zoneName: string;
  alt?: boolean;
}

const { zoneName, alt = false } = Astro.props as Props;
const base = import.meta.env.BASE_URL;
---

<section class={alt ? 'section zp-alt' : 'section'}>
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Services</span>
      <h2>Tous nos services à {zoneName}</h2>
      <p class="lead">
        L'ensemble de nos prestations est disponible à {zoneName} — chaque service a sa page détaillée, avec finitions, méthode et FAQ.
      </p>
    </div>
    <div class="zp-services">
      {servicesListe.map((s) => (
        <a class="card zp-service-card" href={`${base}services/${s.slug}`}>
          <h3>{s.label}</h3>
          <p>{s.resume}</p>
          <span class="zp-more">Découvrir le service →</span>
        </a>
      ))}
    </div>
  </div>
</section>
