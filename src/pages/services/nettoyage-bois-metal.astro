---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Nettoyage bois et métal — Moment D.Art"
  description="Nettoyage et entretien des éléments en bois et en métal : portes, châssis, escaliers, garde-corps et supports spécifiques."
>
  <Header />

  <section class="page-hero">
    <div class="container">
      <div class="card grid-2">
        <div>
          <span class="eyebrow">Service</span>
          <h1>Nettoyage bois et métal</h1>
          <p class="lead">
            Nettoyage et entretien des portes, châssis, boiseries, garde-corps et éléments métalliques afin de préserver leur état et leur propreté.
          </p>
        </div>

        <img
          src="https://images.unsplash.com/photo-1484154218962-a197022b5858?auto=format&fit=crop&w=1400&q=80"
          alt="Nettoyage bois et métal"
          style="border-radius:22px; width:100%; height:100%; object-fit:cover; min-height:320px;"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        <div>
          <h2>Entretenir les éléments spécifiques</h2>
          <p class="lead">
            Le bois et le métal nécessitent un nettoyage adapté pour retirer poussières, traces et encrassement sans nuire aux supports.
          </p>
        </div>

        <div class="card" style="padding:1.5rem;">
          <h3>Éléments traités</h3>
          <p>
            Portes, chambranles, placards, moulures, escaliers, garde-corps, ferronneries et autres éléments en bois ou en métal.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>