---
interface Props {
  title: string;
  description: string;
  meta: string;
  beforeLabel?: string;
  afterLabel?: string;
  beforeImage: string;
  afterImage: string;
}

const {
  title,
  description,
  meta,
  beforeLabel = 'Avant',
  afterLabel = 'Après',
  beforeImage,
  afterImage,
} = Astro.props;
---

<article class="showcase card">
  <div class="showcase-head">
    <div>
      <p class="meta">{meta}</p>
      <h3>{title}</h3>
    </div>
  </div>

  <div class="ba-slider" data-ba-slider>
    <img src={beforeImage} alt={`${title} - ${beforeLabel}`} class="base-image" loading="lazy" />

    <div class="overlay" style="clip-path: inset(0 50% 0 0);">
      <img src={afterImage} alt={`${title} - ${afterLabel}`} class="overlay-image" loading="lazy" />
      <span class="label label-after">{afterLabel}</span>
    </div>

    <div class="before-label-layer" style="clip-path: inset(0 0 0 50%);">
      <span class="label label-before">{beforeLabel}</span>
    </div>

    <input aria-label={`Comparer ${beforeLabel} et ${afterLabel}`} type="range" min="0" max="100" value="50" />

    <div class="divider" style="left: 50%;">
      <div class="handle">
        <svg class="handle-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M8 12H16M8 12L5 9M8 12L5 15M16 12L19 9M16 12L19 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </div>
</article>

<style>
  .showcase {
    padding: 1rem;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 1rem;
    height: 100%;
    background: var(--surface-strong);
    position: relative;
    overflow: hidden;
  }

  .showcase::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.22), rgba(255,255,255,0.03) 40%, transparent 65%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .showcase:hover::before {
    opacity: 1;
  }

  .showcase-head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-items: start;
  }

  .showcase-head > div,
  .showcase-head > p {
    margin: 0;
  }

  .showcase-head h3 {
    margin: 0;
  }

  .meta {
    margin-bottom: 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--accent);
  }

  .ba-slider {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #ece4d8;
    border: 1px solid rgba(23,22,20,0.08);
  }

  .ba-slider::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(18,13,8,0.04), transparent 30%, rgba(18,13,8,0.12));
    pointer-events: none;
  }

  .ba-slider img {
    user-select: none;
    pointer-events: none;
  }

  .base-image,
  .overlay-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .base-image {
    filter: grayscale(0.18) saturate(0.7) brightness(0.96);
  }

  .overlay {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 1;
  }

  .before-label-layer {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 1;
    pointer-events: none;
  }

  .overlay::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    width: 1px;
    background: rgba(255,255,255,0.85);
    pointer-events: none;
  }

  .overlay-image {
    filter: saturate(0.95) contrast(1.02);
  }

  .label {
    position: absolute;
    bottom: 1rem;
    pointer-events: none;
    z-index: 2;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.42rem 0.85rem;
    border-radius: 999px;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(23,22,20,0.08);
    box-shadow: 0 6px 16px rgba(23,22,20,0.12);
  }

  .label-before {
    right: 1rem;
    background: rgba(36,29,23,0.72);
    color: rgba(255,255,255,0.92);
  }

  .label-after {
    left: 1rem;
    background: var(--accent);
    color: #faf7f2;
  }

  .ba-slider input[type='range'] {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: ew-resize;
    margin: 0;
    z-index: 3;
  }

  .divider {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 0;
    pointer-events: none;
    z-index: 2;
  }

  .divider::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 1px;
    background: rgba(255,255,255,0.95);
    box-shadow: 0 0 0 1px rgba(23,22,20,0.08);
  }

  .handle {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 4px 20px rgba(23,22,20,0.22), 0 1px 4px rgba(23,22,20,0.10);
    border: 1.5px solid rgba(23,22,20,0.10);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .handle-icon {
    width: 22px;
    height: 22px;
    color: var(--text);
  }

  @media (max-width: 860px) {
    .showcase {
      padding: 0.9rem;
      gap: 0.85rem;
    }

    .showcase-head {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .ba-slider {
      border-radius: 20px;
    }

    .label {
      font-size: 0.68rem;
      padding: 0.38rem 0.7rem;
    }

    .label-before { right: 0.8rem; }
    .label-after  { left: 0.8rem; }

    .handle {
      width: 46px;
      height: 46px;
    }
  }

  @media (max-width: 560px) {
    .showcase {
      padding: 0.8rem;
      gap: 0.75rem;
      border-radius: 22px;
    }

    .meta {
      font-size: 0.68rem;
      margin-bottom: 0.3rem;
    }

    .showcase-head h3 {
      font-size: 1.05rem;
      line-height: 1.15;
    }

    .ba-slider {
      border-radius: 18px;
      aspect-ratio: 4 / 3;
    }

    .label {
      font-size: 0.62rem;
      padding: 0.32rem 0.6rem;
      bottom: 0.7rem;
    }

    .label-before { right: 0.7rem; }
    .label-after  { left: 0.7rem; }

    .handle {
      width: 42px;
      height: 42px;
    }

    .handle-icon {
      width: 18px;
      height: 18px;
    }

  }
</style>

<script>
  document.querySelectorAll('[data-ba-slider]').forEach((slider) => {
    const input = slider.querySelector('input');
    const overlay = slider.querySelector('.overlay');
    const beforeLabelLayer = slider.querySelector('.before-label-layer');
    const divider = slider.querySelector('.divider');

    const update = () => {
      const value = Number(input.value);
      overlay.style.clipPath = `inset(0 ${100 - value}% 0 0)`;
      beforeLabelLayer.style.clipPath = `inset(0 0 0 ${value}%)`;
      divider.style.left = `${value}%`;
    };

    input.addEventListener('input', update);
    update();
  });
</script>
