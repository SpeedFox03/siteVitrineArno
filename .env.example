# Configuration SMTP pour l'envoi des e-mails
# À configurer dans : Netlify → Site settings → Environment variables

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-adresse@gmail.com
SMTP_PASS=votre-app-password-gmail

# Adresse de destination des formulaires
DEVIS_TO_EMAIL=contact@momentdart.be
CONTACT_TO_EMAIL=contact@momentdart.be
