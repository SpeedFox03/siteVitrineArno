---
import ScrollReveal from '../components/ScrollReveal.astro';
import CookieBanner from '../components/CookieBanner.astro';

const {
  title = 'Peintre à Neupré | Peinture intérieure & enduits décoratifs — Moment D.Art',
  description = "Moment D.Art, entreprise de peinture haut de gamme basée à Neupré : peinture intérieure et extérieure, enduits décoratifs, tadelakt, revêtements muraux, sols et boiseries. Active à Neupré, Liège, Namur, Ciney et dans le Condroz.",
  ogImage = 'https://momentdart.be/images/avant-apres/06-salon-mur-vert-sauge-apres.jpg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, 'https://momentdart.be').href;

// Données structurées globales — siège à Neupré (base officielle), zones réellement desservies.
const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HousePainter',
  '@id': 'https://momentdart.be/#business',
  name: 'Moment D.Art',
  description:
    "Entreprise de peinture haut de gamme basée à Neupré, active en région liégeoise ainsi qu'à Namur, Ciney, Dinant et dans le Condroz : peinture intérieure et extérieure, enduits décoratifs, tadelakt, revêtements muraux et de sol, boiseries et ferronneries.",
  url: 'https://momentdart.be',
  image: 'https://momentdart.be/logo.png',
  logo: 'https://momentdart.be/logo.png',
  email: 'contact@momentdart.be',
  telephone: '+32497282987',
  priceRange: '€€€',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Rue des Moges',
    postalCode: '4120',
    addressLocality: 'Neupré',
    addressRegion: 'Liège',
    addressCountry: 'BE',
  },
  areaServed: [
    'Neupré',
    'Liège',
    'Sprimont',
    'Embourg',
    'Beaufays',
    'Namur',
    'Ciney',
    'Dinant',
    'Hamois',
    'Rochefort',
  ].map((name) => ({ '@type': 'City', name })),
};
---
<!doctype html>
<html lang="fr">
  <head>
    <!-- Google Site Verification -->
    <meta name="google-site-verification" content="a3rwBGgKOfaa1Lzf7icnOddXYdQWBXDtj-g5jWG9O64" />
    <!-- GTM chargé conditionnellement après consentement (voir CookieBanner) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      if (localStorage.getItem('cookie_consent') === 'accepted') {
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-WHDRMPCP');
      }
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicon (onglets navigateurs + résultats Google) -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="fr_BE" />
    <meta property="og:site_name" content="Moment D.Art" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Données structurées : entreprise locale -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(businessSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg: #f6f2eb;
        --bg-soft: #efe9df;
        --surface: rgba(255, 255, 255, 0.72);
        --surface-strong: rgba(255, 255, 255, 0.9);
        --text: #241d17;
        --muted: #655b51;
        --muted-2: #91877b;
        --line: rgba(36, 29, 23, 0.12);
        --line-strong: rgba(36, 29, 23, 0.24);
        --accent: #b18a68;
        --accent-strong: #977353;
        --accent-soft: rgba(177, 138, 104, 0.14);
        --shadow: 0 24px 60px rgba(36, 29, 23, 0.08);
        --radius-xl: 34px;
        --radius-lg: 26px;
        --radius-md: 18px;
        --max: 1240px;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      [id] { scroll-margin-top: 110px; }

      body {
        margin: 0;
        font-family: 'Inter', system-ui, sans-serif;
        color: var(--text);
        background-color: #f6f2eb;
        background-image:
          url('/site-paper-texture.svg'),
          radial-gradient(circle at top left, rgba(177, 138, 104, 0.05), transparent 24%),
          linear-gradient(180deg, #faf7f2 0%, #f6f2eb 35%, #f2ede5 100%);
        background-size: 980px 720px, auto, auto;
        background-position: center top, left top, center top;
        background-repeat: repeat, no-repeat, no-repeat;
        min-height: 100vh;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        opacity: 0.22;
        background-image:
          radial-gradient(rgba(36, 29, 23, 0.10) 0.5px, transparent 0.6px),
          radial-gradient(rgba(177, 138, 104, 0.08) 0.5px, transparent 0.6px);
        background-size: 5px 5px, 6px 6px;
        background-position: 0 0, 6px 6px;
        background-repeat: repeat;
        mix-blend-mode: multiply;
      }

      a { color: inherit; text-decoration: none; }
      img, video { display: block; max-width: 100%; }
      .container { width: min(calc(100% - 2rem), var(--max)); margin: 0 auto; }
      .section { padding: 5.5rem 0; }
      .section-header { max-width: 820px; margin-bottom: 2.25rem; }
      .section-header h2 { margin-bottom: 1rem; }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 0.76rem;
        font-weight: 700;
      }

      .eyebrow::before {
        content: '';
        width: 42px;
        height: 1px;
        background: color-mix(in srgb, var(--accent) 55%, white);
      }

      h1, h2, h3, h4, p { margin: 0; }
      h1, h2 { font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 600; }
      h1 { font-size: clamp(2.1rem, 4.6vw, 4.1rem); line-height: 0.95; letter-spacing: -0.04em; }
      h2 { font-size: clamp(2.35rem, 5vw, 4.2rem); line-height: 1.02; letter-spacing: -0.04em; margin-top: 1rem; }
      h3 { font-size: 1.25rem; line-height: 1.2; }
      p { color: var(--muted); line-height: 1.75; font-size: 1rem; }
      .lead { font-size: 1.08rem; max-width: 65ch; }

      .btn-row { display: flex; flex-wrap: wrap; gap: 0.9rem; }

      .btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 0.6rem;
        padding: 0.95rem 1.35rem; border-radius: 999px; font-weight: 700;
        border: 1px solid transparent; transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, color 0.25s ease;
      }

      .btn:hover { transform: translateY(-1px); }
      .btn-primary { background: var(--accent); color: #faf7f2; }
      .btn-primary:hover { background: var(--accent-strong); }
      .btn-secondary { background: transparent; border-color: var(--line-strong); color: var(--text); }
      .btn-secondary:hover { border-color: color-mix(in srgb, var(--accent) 50%, var(--line-strong)); background: rgba(255,255,255,0.45); }

      .card {
        background: var(--surface);
        border: 1px solid rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(18px);
        box-shadow: var(--shadow);
        border-radius: var(--radius-lg);
      }

      .number { color: var(--accent); font-family: 'Cormorant Garamond', Georgia, serif; font-size: 2.1rem; line-height: 1; }
      .grid-2 { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 1rem; }
      .page-hero { padding: 3rem 0 2rem; }
      .page-hero .card { padding: 1.5rem; }
      .info-list { display: grid; gap: 0.85rem; margin-top: 1.5rem; }
      .info-list div { padding-top: 0.85rem; border-top: 1px solid var(--line); }

      @media (max-width: 900px) {
        .grid-2 { grid-template-columns: 1fr; }
      }

      @media (max-width: 720px) {
        .section { padding: 4rem 0; }
        .section-header { margin-bottom: 1.75rem; }
        h2 { margin-top: 0.75rem; margin-bottom: 0.9rem; }
      }

      /* Blocs partagés par les pages zones et les sections enrichies des pages services (.zp-scope). */
      .zp-scope .zp-alt {
        background: linear-gradient(180deg, rgba(240, 233, 223, 0.55), rgba(246, 242, 235, 0));
      }

      .zp-scope .zp-split {
        display: grid;
        grid-template-columns: 1.35fr 1fr;
        gap: 3rem;
        align-items: start;
      }

      .zp-scope .zp-split h2 { margin-bottom: 1.25rem; }
      .zp-scope .zp-text p + p { margin-top: 1.1rem; }

      .zp-scope .zp-text a,
      .zp-scope .zp-card p a {
        color: #7A5C3E;
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      .zp-scope .zp-text a:hover,
      .zp-scope .zp-card p a:hover { color: #3E2C1C; }

      .zp-scope .zp-card { padding: 1.75rem; }

      .zp-scope .zp-card h3 {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 0.75rem;
      }

      .zp-scope .zp-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 0.7rem;
      }

      .zp-scope .zp-list li {
        position: relative;
        padding-left: 1.35rem;
        font-size: 0.94rem;
        line-height: 1.65;
        color: var(--muted);
      }

      .zp-scope .zp-list li::before {
        content: '—';
        position: absolute;
        left: 0;
        color: var(--accent);
      }

      .zp-scope .zp-services {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-top: 2rem;
      }

      .zp-scope .zp-service-card {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
      }

      .zp-scope .zp-service-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 28px 64px rgba(36, 29, 23, 0.12);
      }

      .zp-scope .zp-service-card h3 { font-size: 1.1rem; color: var(--text); }
      .zp-scope .zp-service-card p { font-size: 0.92rem; line-height: 1.7; }

      .zp-scope .zp-service-card .zp-more {
        margin-top: auto;
        padding-top: 0.5rem;
        font-size: 0.84rem;
        font-weight: 700;
        color: #7A5C3E;
      }

      .zp-scope .zp-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.75rem;
      }

      .zp-scope .zp-chip {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 1.1rem;
        border-radius: 999px;
        border: 1.5px solid rgba(122, 92, 62, 0.35);
        color: #7A5C3E;
        font-size: 0.86rem;
        font-weight: 600;
      }

      .zp-scope a.zp-chip:hover {
        border-color: #7A5C3E;
        background: rgba(122, 92, 62, 0.06);
      }

      .zp-scope span.zp-chip {
        border-style: dashed;
        color: var(--muted);
      }

      @media (max-width: 900px) {
        .zp-scope .zp-split { grid-template-columns: 1fr; gap: 2rem; }
        .zp-scope .zp-services { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <slot />
    <ScrollReveal />
    <CookieBanner />
  </body>
</html>
