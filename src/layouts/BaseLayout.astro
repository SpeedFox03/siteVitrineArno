---
const {
  title = 'Moment D.Art — Peinture haut de gamme à Neupré',
  description = "Moment D.Art, entreprise de peinture haut de gamme à Neupré. Peinture intérieure, extérieure, boiserie, ascenseur, revêtement mural et pose de parquet flottant pour projets résidentiels et professionnels premium.",
} = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg: #f6f2eb;
        --bg-soft: #efe9df;
        --surface: rgba(255, 255, 255, 0.72);
        --surface-strong: rgba(255, 255, 255, 0.9);
        --text: #241d17;
        --muted: #655b51;
        --muted-2: #91877b;
        --line: rgba(36, 29, 23, 0.12);
        --line-strong: rgba(36, 29, 23, 0.24);
        --accent: #b18a68;
        --accent-strong: #977353;
        --accent-soft: rgba(177, 138, 104, 0.14);
        --shadow: 0 24px 60px rgba(36, 29, 23, 0.08);
        --radius-xl: 34px;
        --radius-lg: 26px;
        --radius-md: 18px;
        --max: 1240px;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: 'Inter', system-ui, sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(177, 138, 104, 0.05), transparent 24%),
          linear-gradient(180deg, #faf7f2 0%, #f6f2eb 35%, #f2ede5 100%);
        min-height: 100vh;
      }

      a { color: inherit; text-decoration: none; }
      img, video { display: block; max-width: 100%; }
      .container { width: min(calc(100% - 2rem), var(--max)); margin: 0 auto; }
      .section { padding: 5.5rem 0; }
      .section-header { max-width: 820px; margin-bottom: 2.25rem; }
      .section-header h2 { margin-bottom: 1rem; }
      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 0.76rem;
        font-weight: 700;
      }
      .eyebrow::before {
        content: '';
        width: 42px;
        height: 1px;
        background: color-mix(in srgb, var(--accent) 55%, white);
      }
      h1, h2, h3, h4, p { margin: 0; }
      h1, h2 { font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 600; }
      h1 { font-size: clamp(3.2rem, 7vw, 6.2rem); line-height: 0.95; letter-spacing: -0.04em; }
      h2 { font-size: clamp(2.35rem, 5vw, 4.2rem); line-height: 1.02; letter-spacing: -0.04em; margin-top: 1rem; }
      h3 { font-size: 1.25rem; line-height: 1.2; }
      p { color: var(--muted); line-height: 1.75; font-size: 1rem; }
      .lead { font-size: 1.08rem; max-width: 65ch; }
      .btn-row { display: flex; flex-wrap: wrap; gap: 0.9rem; }
      .btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 0.6rem;
        padding: 0.95rem 1.35rem; border-radius: 999px; font-weight: 700;
        border: 1px solid transparent; transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, color 0.25s ease;
      }
      .btn:hover { transform: translateY(-1px); }
      .btn-primary { background: var(--accent); color: #faf7f2; }
      .btn-primary:hover { background: var(--accent-strong); }
      .btn-secondary { background: transparent; border-color: var(--line-strong); color: var(--text); }
      .btn-secondary:hover { border-color: color-mix(in srgb, var(--accent) 50%, var(--line-strong)); background: rgba(255,255,255,0.45); }
      .card {
        background: var(--surface);
        border: 1px solid rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(18px);
        box-shadow: var(--shadow);
        border-radius: var(--radius-lg);
      }
      .number { color: var(--accent); font-family: 'Cormorant Garamond', Georgia, serif; font-size: 2.1rem; line-height: 1; }
      .grid-2 { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 1rem; }
      .page-hero { padding: 3rem 0 2rem; }
      .page-hero .card { padding: 1.5rem; }
      .info-list { display: grid; gap: 0.85rem; margin-top: 1.5rem; }
      .info-list div { padding-top: 0.85rem; border-top: 1px solid var(--line); }
      @media (max-width: 900px) { .grid-2 { grid-template-columns: 1fr; } }
      @media (max-width: 720px) {
        .section { padding: 4rem 0; }
        .section-header { margin-bottom: 1.75rem; }
        h2 { margin-top: 0.75rem; margin-bottom: 0.9rem; }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
