---
const baseUrl = import.meta.env.BASE_URL;

const navItems = [
  {
    label: 'Accueil',
    href: baseUrl,
    icon: `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" aria-hidden="true">
  <path d="M5.5 15.2 16 6.5l10.5 8.7" />
  <path d="M8.5 14.2v11.3h15V14.2" />
  <path d="M13 25.5v-7h6v7" />
</svg>`,
  },
  {
    label: 'Services',
    href: `${baseUrl}services`,
    icon: `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" aria-hidden="true">
  <path d="m20.5 5.5 6 6-11.8 11.8-6.5 1.5 1.5-6.5L20.5 5.5Z" />
  <path d="m18.4 7.7 5.9 5.9" />
  <path d="M7 26h18" />
</svg>`,
  },
  {
    label: 'Réalisations',
    href: `${baseUrl}realisations`,
    icon: `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" aria-hidden="true">
  <path d="M7 8.5h18v15H7z" />
  <path d="m9.5 21 5.2-5.8 4.2 4.3 2.4-2.8 3.2 4.3" />
  <path d="M20.5 12.5h.1" />
</svg>`,
  },
  {
    label: 'Zones',
    href: `${baseUrl}zones-intervention`,
    icon: `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" aria-hidden="true">
  <path d="M16 26.5s-8.5-7.8-8.5-13.2a8.5 8.5 0 0 1 17 0c0 5.4-8.5 13.2-8.5 13.2Z" />
  <path d="M16 16.4a3.2 3.2 0 1 0 0-6.4 3.2 3.2 0 0 0 0 6.4Z" />
</svg>`,
  },
  {
    label: 'À propos',
    href: `${baseUrl}a-propos`,
    icon: `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" aria-hidden="true">
  <path d="M16 17.5c4.5 0 8 3.1 8 7v.7H8v-.7c0-3.9 3.5-7 8-7Z" />
  <path d="M16 14.2a4.3 4.3 0 1 0 0-8.6 4.3 4.3 0 0 0 0 8.6Z" />
</svg>`,
  },
  {
    label: 'Contact',
    href: `${baseUrl}#contact`,
    icon: `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" aria-hidden="true">
  <path d="M6.5 9.5h19v13h-19z" />
  <path d="m7 10 9 7.2 9-7.2" />
  <path d="m7.4 22 6.4-6" />
  <path d="m24.6 22-6.4-6" />
</svg>`,
  },
  {
    label: 'Devis',
    href: `${baseUrl}devis`,
    featured: true,
    icon: `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" aria-hidden="true">
  <path d="M9 5.5h10l4 4v17H9z" />
  <path d="M19 5.5v4h4" />
  <path d="M12.5 14h7" />
  <path d="M12.5 18h7" />
  <path d="M12.5 22h4.5" />
</svg>`,
  },
];
---

<header class="site-header">
  <div class="container header-shell">
    <div class="header-inner" data-header>
      <a class="mobile-brand" href={baseUrl} aria-label="Moment D.Art accueil">
        <span class="brand-mark"><img src={`${baseUrl}logo.png`} alt="" loading="eager" /></span>
      </a>

      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu" data-menu-toggle>
        <span></span>
        <span></span>
        <span></span>
        <span class="sr-only">Ouvrir le menu</span>
      </button>

      <nav id="site-menu" class="site-nav" aria-label="Navigation principale" data-menu>
        <ul>
          <li class="brand-item">
            <a class="brand" href={baseUrl} aria-label="Moment D.Art accueil">
              <span class="brand-mark"><img src={`${baseUrl}logo.png`} alt="" loading="eager" /></span>
            </a>
          </li>

          {navItems.map((item) => (
            <li class={item.featured ? 'nav-featured' : undefined}>
              <a href={item.href}>
                <span class="nav-icon" set:html={item.icon}></span>
                <span class="nav-label">{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</header>

<div class="mobile-header-spacer" aria-hidden="true"></div>

<script>
  const siteHeader = document.querySelector('.site-header');
  const header = document.querySelector('[data-header]');
  const menuToggle = document.querySelector('[data-menu-toggle]');
  const menu = document.querySelector('[data-menu]');

  let lastScrollY = window.scrollY;

  const updateHeaderScrollState = () => {
    if (!header || !siteHeader) return;

    const currentScrollY = window.scrollY;
    const delta = currentScrollY - lastScrollY;
    const isMobile = window.innerWidth <= 980;

    if (isMobile) {
      if (header.classList.contains('menu-open')) {
        siteHeader.classList.remove('is-hidden');
      } else if (delta > 8 && currentScrollY > 90) {
        siteHeader.classList.add('is-hidden');
      } else if (delta < -8 || currentScrollY <= 90) {
        siteHeader.classList.remove('is-hidden');
      }
    } else {
      siteHeader.classList.remove('is-hidden');
    }

    lastScrollY = currentScrollY;
  };

  const closeMobileMenu = () => {
    if (!header || window.innerWidth > 980) return;
    header.classList.remove('menu-open');
    menuToggle?.setAttribute('aria-expanded', 'false');
    siteHeader?.classList.remove('is-hidden');
  };

  menuToggle?.addEventListener('click', () => {
    const isOpen = header?.classList.toggle('menu-open');
    menuToggle?.setAttribute('aria-expanded', String(Boolean(isOpen)));

    if (isOpen) {
      siteHeader?.classList.remove('is-hidden');
    }
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 980) {
      header?.classList.remove('menu-open');
      menuToggle?.setAttribute('aria-expanded', 'false');
    }

    siteHeader?.classList.remove('is-hidden');
    lastScrollY = window.scrollY;
    updateHeaderScrollState();
  });

  window.addEventListener('scroll', updateHeaderScrollState, { passive: true });
  updateHeaderScrollState();
</script>

<style>
  .site-header {
    --paper-mesh: url("/paint-nav.svg");
    --paper-ink: #8f715a;
    --paper-ink-strong: #745947;
    --nav-accent: #b7764e;
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 1.05rem 0 0.55rem;
    transition: transform 0.28s ease, opacity 0.28s ease;
  }

  .site-header.is-hidden {
    transform: translateY(calc(-100% - 1.5rem));
    opacity: 0;
    pointer-events: none;
  }

  .mobile-header-spacer,
  .mobile-brand {
    display: none;
  }

  .header-shell {
    position: relative;
  }

  .header-inner {
    position: relative;
    min-height: 112px;
    isolation: isolate;
    opacity: 0.90;
  }

  .header-inner::after {
    content: '';
    position: absolute;
    left: 2.15rem;
    right: 2.15rem;
    top: 78px;
    z-index: 0;
    height: 24px;
    pointer-events: none;
    border-radius: 999px;
    background: rgba(72, 61, 49, 0.24);
    filter: blur(9px);
    opacity: 0.22;
    transform: perspective(260px) rotateX(64deg);
    transform-origin: top;
  }

  .site-nav {
    position: relative;
    z-index: 1;
    height: 90px;
    min-width: 0;
    color: var(--paper-ink);
    background-color: #faf3e8;
    background-image: var(--paper-mesh);
    background-size: 100% 100%;
    background-repeat: no-repeat;
    background-position: center;
    border: 1px solid rgba(143, 119, 86, 0.14);
    border-radius: 14px;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.78) inset,
      0 3px 8px -6px rgba(70, 60, 47, 0.12);
    overflow: visible;
  }

  .site-nav::after {
    content: '';
    position: absolute;
    left: 2rem;
    right: 2rem;
    bottom: -14px;
    z-index: -1;
    height: 22px;
    border-radius: 999px;
    background: rgba(78, 68, 54, 0.26);
    filter: blur(8px);
    opacity: 0.2;
    transform: perspective(230px) rotateX(58deg);
    transform-origin: top;
  }

  .site-nav::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    border-radius: inherit;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55);
  }

  .site-nav ul {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    height: 100%;
    list-style: none;
    padding: 0;
    margin: 0;
    border-radius: inherit;
    overflow: hidden;
  }

  .site-nav li {
    position: relative;
    min-width: 0;
    display: flex;
    overflow: hidden;
  }

  .site-nav li + li::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 2;
    width: 1px;
    background: rgba(143, 119, 86, 0.16);
  }

  .site-nav li::after {
    display: none;
  }

  .site-nav a,
  .mobile-brand {
    text-decoration: none;
  }

  .site-nav a {
    position: relative;
    z-index: 1;
    display: flex;
    flex: 1 1 auto;
    min-width: 0;
    height: 100%;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.36rem;
    padding: 0.62rem 0.42rem 0.74rem;
    color: var(--paper-ink);
    text-align: center;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.72);
    transition: color 0.22s ease, transform 0.22s ease;
  }

  .site-nav a::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0.62rem;
    width: 28px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    opacity: 0;
    transform: translateX(-50%) scaleX(0.5);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }

  .site-nav a:hover,
  .site-nav a:focus-visible {
    color: var(--nav-accent);
    transform: translateY(-2px);
  }

  .site-nav a:hover::after,
  .site-nav a:focus-visible::after {
    opacity: 0.32;
    transform: translateX(-50%) scaleX(1);
  }

  .site-nav .nav-featured a {
    color: #b76f45;
  }

  .site-nav .nav-featured a:hover,
  .site-nav .nav-featured a:focus-visible {
    color: #a65f39;
  }

  .site-nav .nav-featured a::after {
    opacity: 0.28;
    transform: translateX(-50%) scaleX(1);
  }

  .site-nav .nav-featured .nav-icon :global(svg) {
    stroke-width: 2;
  }

  .site-nav .nav-featured .nav-label {
    font-weight: 900;
  }

  .brand,
  .mobile-brand {
    color: #6e5947;
  }

  .brand {
    padding-top: 0.54rem;
    padding-bottom: 0.52rem;
  }

  .brand::after {
    display: none;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 110px;
    height: 85px;
    transform: translateY(-13px);
  }

  .brand-mark img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0.78;
    filter: saturate(0.78) contrast(0.92);
  }

  .nav-icon {
    display: grid;
    place-items: center;
    width: 29px;
    height: 29px;
    color: currentColor;
  }

  .nav-icon :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.7;
  }

  .nav-label {
    display: block;
    max-width: 100%;
    overflow-wrap: anywhere;
    font-size: 0.66rem;
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .menu-toggle,
  .sr-only {
    display: none;
  }

  @media (max-width: 1180px) {
    .site-nav {
      height: 86px;
    }

    .brand-mark {
      width: 82px;
      height: 62px;
    }

    .nav-icon {
      width: 26px;
      height: 26px;
    }

    .nav-label {
      font-size: 0.59rem;
    }
  }

  @media (max-width: 980px) {
    .site-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      padding: 0.55rem 0 0;
      will-change: transform;
    }

    .mobile-header-spacer {
      display: block;
      height: 88px;
    }

    .header-inner {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      min-height: 72px;
      padding: 0.68rem 0.78rem;
      opacity: 1;
      border: 1px solid rgba(143, 119, 86, 0.14);
      border-radius: 14px;
      background-color: #faf3e8;
      background-image: var(--paper-mesh);
      background-size: 100% 100%;
      background-position: center;
      box-shadow:
        0 1px 0 rgba(255, 255, 255, 0.78) inset,
        0 12px 22px rgba(70, 60, 47, 0.08);
    }

    .header-inner.menu-open {
      background-image: var(--paper-mesh);
      background-repeat: no-repeat;
      background-position: center;
      background-size: 100% 100%;
      box-shadow: none;
    }

    .header-inner.menu-open::after {
      opacity: 0;
    }

    .header-inner::after {
      left: 1.2rem;
      right: 1.2rem;
      top: 62px;
      height: 24px;
      filter: blur(8px);
      opacity: 0.44;
    }

    .mobile-brand {
      grid-column: 1;
      grid-row: 1;
      display: inline-grid;
      align-items: center;
      justify-self: start;
      min-width: 0;
    }

    .mobile-brand .brand-mark {
      width: 80px;
      height: 60px;
    }

    .menu-toggle {
      grid-column: 2;
      grid-row: 1;
      justify-self: end;
      display: inline-flex;
      flex-direction: column;
      justify-content: center;
      gap: 0.28rem;
      width: 44px;
      height: 44px;
      border-radius: 999px;
      border: 1px solid rgba(122, 92, 62, 0.22);
      background: rgba(255, 255, 255, 0.36);
      padding: 0 0.75rem;
      cursor: pointer;
      transition: background 0.25s ease, border-color 0.25s ease;
    }

    .menu-toggle:hover,
    .menu-toggle:focus-visible {
      border-color: rgba(200, 121, 69, 0.4);
      background: rgba(255, 255, 255, 0.52);
    }

    .menu-toggle span {
      display: block;
      height: 1.5px;
      background: #241d17;
      border-radius: 999px;
      transition: transform 0.25s ease, opacity 0.25s ease;
    }

    .menu-toggle .sr-only {
      display: inline;
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
    }

    .header-inner.menu-open .menu-toggle span:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }

    .header-inner.menu-open .menu-toggle span:nth-child(2) {
      opacity: 0;
    }

    .header-inner.menu-open .menu-toggle span:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }

    .site-nav {
      grid-column: 1 / -1;
      width: 100%;
      height: auto;
      display: grid;
      grid-template-rows: 0fr;
      visibility: hidden;
      border: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
      transition:
        grid-template-rows 0.44s cubic-bezier(0.22, 1, 0.36, 1),
        visibility 0s linear 0.44s;
    }

    .site-nav::after {
      display: none;
    }

    .site-nav::before {
      display: none;
    }

    .header-inner.menu-open .site-nav {
      grid-template-rows: 1fr;
      visibility: visible;
      transition:
        grid-template-rows 0.46s cubic-bezier(0.22, 1, 0.36, 1),
        visibility 0s;
    }

    .site-nav ul {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.18rem;
      height: auto;
      min-height: 0;
      padding-top: 0;
      overflow: hidden;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    /* espacement porté par le 1er item (se replie avec le menu, contrairement au padding du ul) */
    .site-nav .brand-item + li {
      margin-top: 1.85rem;
    }

    /* barre de séparation descendue sous le bouton menu */
    .site-nav ul::before {
      content: '';
      position: absolute;
      top: 1rem;
      left: 0;
      right: 0;
      height: 1px;
      background: rgba(122, 92, 62, 0.14);
    }

    .header-inner.menu-open .site-nav ul {
      opacity: 1;
      transition-delay: 0.06s;
    }

    .site-nav .brand-item {
      display: none;
    }

    .site-nav li {
      min-height: 52px;
      border-radius: 10px;
      opacity: 0;
      transform: translateY(12px);
      transition:
        opacity 0.4s ease,
        transform 0.46s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .header-inner.menu-open .site-nav li {
      opacity: 1;
      transform: translateY(0);
    }

    /* cascade : la 1re entrée (.brand-item) est masquée, on décale à partir de la 2e */
    .header-inner.menu-open .site-nav li:nth-child(2) { transition-delay: 0.06s; }
    .header-inner.menu-open .site-nav li:nth-child(3) { transition-delay: 0.11s; }
    .header-inner.menu-open .site-nav li:nth-child(4) { transition-delay: 0.16s; }
    .header-inner.menu-open .site-nav li:nth-child(5) { transition-delay: 0.21s; }
    .header-inner.menu-open .site-nav li:nth-child(6) { transition-delay: 0.26s; }
    .header-inner.menu-open .site-nav li:nth-child(7) { transition-delay: 0.31s; }
    .header-inner.menu-open .site-nav li:nth-child(8) { transition-delay: 0.36s; }

    .site-nav li + li::before {
      display: none;
    }

    .site-nav li::after {
      display: none;
    }

    .site-nav a {
      min-height: 52px;
      flex-direction: row;
      justify-content: flex-start;
      gap: 0.85rem;
      padding: 0.72rem 0.4rem;
      text-align: left;
      transform: none;
    }

    .site-nav .nav-featured a {
      color: #b76f45;
    }

    .site-nav a::after {
      display: none;
    }

    .site-nav a:hover,
    .site-nav a:focus-visible {
      transform: none;
    }

    .nav-icon {
      width: 25px;
      height: 25px;
      flex: 0 0 auto;
    }

    .nav-label {
      font-size: 0.78rem;
      overflow-wrap: normal;
    }
  }

  @media (max-width: 560px) {
    .site-header {
      padding-top: 0.45rem;
    }

    .mobile-header-spacer {
      height: 82px;
    }

    .header-inner {
      min-height: 68px;
      padding: 0.64rem 0.7rem;
    }

    .mobile-brand .brand-mark {
      width: 60px;
      height: 46px;
      transform: translateY(-8px);
    }

    .menu-toggle {
      width: 42px;
      height: 42px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-nav,
    .site-nav ul,
    .site-nav li,
    .menu-toggle span {
      transition-duration: 0.01ms !important;
      transition-delay: 0s !important;
    }
  }
</style>
