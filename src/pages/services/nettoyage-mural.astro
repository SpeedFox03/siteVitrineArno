---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Nettoyage mural — Moment D.Art"
  description="Nettoyage de surfaces murales, entretien des murs intérieurs et remise en état des zones verticales."
>
  <Header />

  <section class="page-hero">
    <div class="container">
      <div class="card grid-2">
        <div>
          <span class="eyebrow">Service</span>
          <h1>Nettoyage mural</h1>
          <p class="lead">
            Nettoyage de surfaces murales pour éliminer traces, poussières et salissures sur les zones verticales intérieures.
          </p>
        </div>

        <img
          src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1400&q=80"
          alt="Nettoyage mural"
          style="border-radius:22px; width:100%; height:100%; object-fit:cover; min-height:320px;"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        <div>
          <h2>Entretenir les surfaces verticales</h2>
          <p class="lead">
            Le nettoyage mural permet de conserver des surfaces propres dans les espaces de vie, halls, couloirs et autres zones exposées au passage.
          </p>
        </div>

        <div class="card" style="padding:1.5rem;">
          <h3>Usages</h3>
          <p>
            Murs intérieurs, surfaces verticales, zones fréquentées et espaces nécessitant un entretien visuel et sanitaire régulier.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>