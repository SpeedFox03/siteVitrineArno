---
import BeforeAfterSlider from './BeforeAfterSlider.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const projects = [
  {
    meta: 'Peinture décorative · Chambre',
    title: 'Mur accent et rénovation chambre',
    description: `Transformation d’une chambre par un travail sur la couleur et le volume — du mur orange existant vers un rendu neutre et contemporain.`,
    beforeImage: `${base}/images/peinture-interieure/chambre-renovation-avant-crop.jpg`,
    afterImage: `${base}/images/peinture-interieure/chambre-renovation-apres-crop.jpg`,
  },
  {
    meta: 'Rénovation intérieure · Pièce à vivre',
    title: 'Remise en état complète — murs et finitions',
    description: `Pièce entièrement décapée, murs repris de zéro et repeints en teinte neutre sablée — résultat propre et habitable.`,
    beforeImage: `${base}/images/peinture-interieure/piece-renovation-avant.jpg`,
    afterImage: `${base}/images/peinture-interieure/piece-renovation-apres.jpg`,
  },
];
---

<section class="section" id="realisations-home" data-realisations-section>
  <div class="container">
    <div class="section-header realisations-reveal-head" data-realisations-reveal>
      <span class="eyebrow">Réalisations</span>
      <h2>Le avant / après reste la preuve centrale du savoir-faire.</h2>
    </div>

    <div class="showcases">
      {projects.map((project, index) => (
        <div
          class="showcase-item realisations-reveal-card"
          data-realisations-reveal
          style={`--reveal-delay: ${0.16 * (index + 1)}s;`}
        >
          <BeforeAfterSlider {...project} />
        </div>
      ))}
    </div>

    <div class="more-link realisations-reveal-link" data-realisations-reveal style="--reveal-delay: 0.42s;">
      <a class="btn btn-secondary" href={`${import.meta.env.BASE_URL}/realisations`}>Voir toutes les réalisations</a>
    </div>
  </div>
</section>

<style>
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.74rem;
    font-weight: 700;
    color: #7A5C3E;
  }

  .eyebrow::before {
    content: '';
    width: 28px;
    height: 1px;
    background: rgba(122, 92, 62, 0.42);
  }

  .showcases {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    align-items: stretch;
  }

  .showcase-item {
    min-width: 0;
    height: 100%;
    display: flex;
  }

  .showcase-item :global(.showcase) {
    width: 100%;
    height: 100%;
  }

  .showcases > .showcase-item:last-child:nth-child(odd) {
    grid-column: 1 / -1;
    max-width: calc(50% - 0.5rem);
    justify-self: center;
    width: 100%;
  }

  .more-link {
    margin-top: 1.2rem;
  }

  .realisations-reveal-head,
  .realisations-reveal-card,
  .realisations-reveal-link {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.85s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0s);
    will-change: opacity, transform;
  }

  .realisations-reveal-head.is-visible,
  .realisations-reveal-card.is-visible,
  .realisations-reveal-link.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .realisations-reveal-head {
    --reveal-delay: 0s;
  }

  @media (prefers-reduced-motion: reduce) {
    .realisations-reveal-head,
    .realisations-reveal-card,
    .realisations-reveal-link {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (max-width: 980px) {
    .showcases {
      grid-template-columns: 1fr;
    }

    .showcases > .showcase-item:last-child:nth-child(odd) {
      grid-column: auto;
      max-width: 100%;
      justify-self: stretch;
    }
  }
</style>

<script>
  const realisationsSection = document.querySelector('[data-realisations-section]');

  if (realisationsSection && typeof window !== 'undefined') {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const items = realisationsSection.querySelectorAll('[data-realisations-reveal]');

    if (prefersReducedMotion) {
      items.forEach((item) => item.classList.add('is-visible'));
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              setTimeout(() => {
                items.forEach((item) => item.classList.add('is-visible'));
              }, 180);

              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.18,
          rootMargin: '0px 0px -8% 0px',
        }
      );

      observer.observe(realisationsSection);
    }
  }
</script>
