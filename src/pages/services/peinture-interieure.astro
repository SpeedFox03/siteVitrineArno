---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import QuoteSection from '../../components/QuoteSection.astro';
import ServicesNav from '../../components/ServicesNav.astro';
---
<BaseLayout
  title="Peinture intérieure haut de gamme — Moment D.Art"
  description="Peinture intérieure haut de gamme à Neupré et en province de Liège. Murs, plafonds, cages d'escalier : préparation soignée, finitions premium, résultat irréprochable."
>
  <Header />

  <section class="page-hero">
    <div class="container">
      <div class="card grid-2 hero-card">
        <div>
          <span class="eyebrow">Service</span>
          <h1>Peinture intérieure</h1>
          <p class="lead">
            Murs, plafonds, cages d'escalier et espaces de vie traités avec précision pour un rendu net, lumineux et durablement haut de gamme.
          </p>
        </div>
        <img
          src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1400&q=80"
          alt="Peinture intérieure haut de gamme"
          style="border-radius:22px; width:100%; height:100%; object-fit:cover; min-height:320px;"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        <div>
          <span class="eyebrow">Contexte</span>
          <h2>Pour quels projets ?</h2>
          <p class="lead">
            Appartements, maisons individuelles, biens en rénovation et propriétés à valoriser avant mise en vente ou location.
            L'objectif est une lecture plus nette des volumes, une palette cohérente et une qualité de surface irréprochable.
          </p>
          <p style="margin-top: 1rem;">
            Chaque chantier démarre par une visite pour évaluer l'état des supports et définir ensemble les teintes, les finitions et les priorités d'intervention.
          </p>
        </div>
        <div class="card detail-card">
          <h3>Ce qu'Arno fait concrètement</h3>
          <ul class="detail-list">
            <li>Protection du mobilier et des sols</li>
            <li>Rebouchage, ponçage et reprise des fissures</li>
            <li>Application d'une impression selon le support</li>
            <li>Deux couches de peinture au minimum</li>
            <li>Finition mate, velours ou satin selon l'usage de la pièce</li>
            <li>Nettoyage complet en fin de chantier</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <span class="eyebrow">Finitions</span>
      <h2>Choisir la bonne finition</h2>
      <div class="finishes-grid">
        <div class="card finish-card">
          <h3>Mat</h3>
          <p>Absorbe la lumière, cache les imperfections de surface. Idéal pour les chambres et espaces calmes.</p>
        </div>
        <div class="card finish-card">
          <h3>Velours</h3>
          <p>Légèrement satiné, facile à entretenir. Polyvalent pour séjours, couloirs et pièces de vie.</p>
        </div>
        <div class="card finish-card">
          <h3>Satin</h3>
          <p>Rendu brillant, très résistant aux frottements. Recommandé pour cuisines, salles de bain et espaces humides.</p>
        </div>
      </div>
    </div>
  </section>

  <ServicesNav current="Peinture intérieure" />
  <QuoteSection />
  <Footer />
</BaseLayout>

<style>
  .hero-card > div:first-child {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.76rem;
    font-weight: 700;
  }

  .eyebrow::before {
    content: '';
    width: 42px;
    height: 1px;
    background: color-mix(in srgb, var(--accent) 55%, white);
  }

  .detail-card {
    padding: 1.5rem;
  }

  .detail-card h3 {
    margin-bottom: 1rem;
  }

  .detail-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.65rem;
  }

  .detail-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.5;
    padding-top: 0.65rem;
    border-top: 1px solid var(--line);
  }

  .detail-list li:first-child {
    border-top: none;
    padding-top: 0;
  }

  .detail-list li::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    margin-top: 0.45rem;
  }

  .section-alt {
    background: rgba(177, 138, 104, 0.04);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .finishes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .finish-card {
    padding: 1.4rem;
  }

  .finish-card h3 {
    margin-bottom: 0.6rem;
    color: var(--accent-strong);
  }

  @media (max-width: 900px) {
    .finishes-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .hero-card {
      grid-template-columns: 1fr;
    }
  }
</style>