---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Nettoyage extérieur — Moment D.Art"
  description="Nettoyage extérieur de façades, annexes et surfaces exposées. Entretien des éléments extérieurs et remise en état des supports."
>
  <Header />

  <section class="page-hero">
    <div class="container">
      <div class="card grid-2">
        <div>
          <span class="eyebrow">Service</span>
          <h1>Nettoyage extérieur</h1>
          <p class="lead">
            Nettoyage de façades, annexes et éléments extérieurs afin d’éliminer salissures, dépôts et traces liées aux conditions climatiques.
          </p>
        </div>

        <img
          src="https://images.unsplash.com/photo-1448630360428-65456885c650?auto=format&fit=crop&w=1400&q=80"
          alt="Nettoyage extérieur"
          style="border-radius:22px; width:100%; height:100%; object-fit:cover; min-height:320px;"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        <div>
          <h2>Un entretien utile dans le temps</h2>
          <p class="lead">
            Les surfaces extérieures demandent un entretien régulier pour limiter l’encrassement, préserver leur état général et conserver un aspect propre.
          </p>
        </div>

        <div class="card" style="padding:1.5rem;">
          <h3>Applications</h3>
          <p>
            Murs extérieurs, annexes, éléments de façade et zones périphériques nécessitant un nettoyage adapté à l’usage du bâtiment.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>