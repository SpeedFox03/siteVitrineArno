---
// Fil d'Ariane visible + données structurées BreadcrumbList.
// Le dernier élément représente la page courante (pas de lien).
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props as Props;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.label,
    ...(item.href ? { item: new URL(item.href, 'https://momentdart.be').href } : {}),
  })),
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

<nav class="breadcrumb" aria-label="Fil d'Ariane">
  <div class="container">
    <ol>
      {items.map((item, i) => (
        <li>
          {item.href && i < items.length - 1 ? (
            <a href={item.href}>{item.label}</a>
          ) : (
            <span aria-current="page">{item.label}</span>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>

<style>
  .breadcrumb {
    padding-top: 1.25rem;
  }

  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.8rem;
    color: var(--muted-2);
  }

  .breadcrumb li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .breadcrumb li + li::before {
    content: '›';
    color: var(--muted-2);
  }

  .breadcrumb a {
    color: #7A5C3E;
    transition: color 0.2s ease;
  }

  .breadcrumb a:hover {
    color: #3E2C1C;
  }

  .breadcrumb span[aria-current] {
    color: var(--muted);
  }
</style>
