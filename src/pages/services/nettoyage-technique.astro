---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Nettoyage technique — Moment D.Art"
  description="Nettoyage de surfaces techniques, locaux professionnels, ateliers, zones de circulation et espaces soumis à des contraintes d’usage."
>
  <Header />

  <section class="page-hero">
    <div class="container">
      <div class="card grid-2">
        <div>
          <span class="eyebrow">Service</span>
          <h1>Nettoyage technique</h1>
          <p class="lead">
            Interventions de nettoyage pour locaux professionnels, surfaces sollicitées et environnements nécessitant une méthode adaptée aux contraintes du lieu.
          </p>
        </div>

        <img
          src="https://images.unsplash.com/photo-1513694203232-719a280e022f?auto=format&fit=crop&w=1400&q=80"
          alt="Nettoyage technique"
          style="border-radius:22px; width:100%; height:100%; object-fit:cover; min-height:320px;"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        <div>
          <h2>Des solutions adaptées à l’usage</h2>
          <p class="lead">
            Le nettoyage technique convient aux espaces professionnels, ateliers, circulations, garages et zones où l’entretien régulier est essentiel.
          </p>
        </div>

        <div class="card" style="padding:1.5rem;">
          <h3>Applications</h3>
          <p>
            Sols, murs, supports techniques et éléments exposés à l’usure quotidienne, avec une approche adaptée à l’activité du site.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>