---
const base = import.meta.env.BASE_URL;
---

<footer class="section footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <img src={`${import.meta.env.BASE_URL}images/logo-premium-transparent.png`} alt="Logo Moment D.Art" class="footer-logo" />
      <p>Moment D.Art · Arno Momin · Rue des Moges · 4120 Neupré</p>
    </div>

    <div class="footer-links">
      <a href={`${import.meta.env.BASE_URL}`}>Accueil</a>
      <a href={`${import.meta.env.BASE_URL}/services`}}>Services</a>
      <a href={`${import.meta.env.BASE_URL}/realisations`}}>Réalisations</a>
      <a href={`${import.meta.env.BASE_URL}/devis`}}>Devis</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding-top: 2rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid var(--line);
    padding-top: 2rem;
  }

  .footer-brand {
    max-width: 36rem;
  }

  .footer-logo {
    width: 240px;
    margin-bottom: 1rem;
  }

  .footer-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: flex-start;
  }

  .footer-links a {
    color: #7A5C3E;
    position: relative;
    transition: color 0.25s ease;
  }

  .footer-links a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.28rem;
    width: 100%;
    height: 1px;
    background: rgba(122, 92, 62, 0.45);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .footer-links a:hover {
    color: #3E2C1C;
  }

  .footer-links a:hover::after {
    transform: scaleX(1);
  }

  @media (max-width: 720px) {
    .footer-inner {
      flex-direction: column;
    }
  }
</style>