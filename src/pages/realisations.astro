---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BeforeAfterSlider from '../components/BeforeAfterSlider.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    meta: 'Appartement · Neupré',
    title: 'Nettoyage intérieur complet',
    description: 'Remise en état des murs, plafonds et surfaces pour retrouver un environnement propre et sain.',
    beforeImage: 'https://images.unsplash.com/photo-1494526585095-c41746248156?auto=format&fit=crop&w=1400&q=80',
    afterImage: 'https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1400&q=80',
  },
  {
    meta: 'Maison · Province de Liège',
    title: 'Remise en état des surfaces',
    description: 'Nettoyage approfondi et entretien global pour améliorer l’état général du bâtiment.',
    beforeImage: 'https://images.unsplash.com/photo-1513694203232-719a280e022f?auto=format&fit=crop&w=1400&q=80',
    afterImage: 'https://images.unsplash.com/photo-1449844908441-8829872d2607?auto=format&fit=crop&w=1400&q=80',
  },
  {
    meta: 'Local professionnel',
    title: 'Nettoyage d’un espace recevant du public',
    description: 'Intervention pour assurer propreté, hygiène et entretien des zones fréquentées.',
    beforeImage: 'https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1400&q=80',
    afterImage: 'https://images.unsplash.com/photo-1497366412874-3415097a27e7?auto=format&fit=crop&w=1400&q=80',
  },
];
---

<BaseLayout title="Interventions — Moment D.Art">
  <Header />

  <section class="page-hero">
    <div class="container">
      <div class="card" style="padding:1.5rem;">
        <span class="eyebrow">Interventions</span>
        <h1>Exemples de nettoyage et remise en état.</h1>
        <p class="lead">
          Présentation d’interventions de nettoyage avant / après, illustrant la remise en état de différents types de surfaces.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="display:grid; gap:1rem;">
        {projects.map((project) => <BeforeAfterSlider {...project} />)}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>