---
import { logoSvg } from '../utils/icons';

const serviceItems = [
  { href: `${import.meta.env.BASE_URL}/services/peinture-interieure`, label: 'Peinture intérieure' },
  { href: `${import.meta.env.BASE_URL}/services/peinture-exterieure`, label: 'Peinture extérieure' },
  { href: `${import.meta.env.BASE_URL}/services/peinture-industrielle-et-epoxy`, label: 'Peinture industrielle et époxy' },
  { href: `${import.meta.env.BASE_URL}/services/revetement-de-sol`, label: 'Revêtement de sol' },
  { href: `${import.meta.env.BASE_URL}/services/revetement-mural`, label: 'Revêtement mural' },
  { href: `${import.meta.env.BASE_URL}/services/boiserie-et-ferronneries`, label: 'Boiserie et ferronneries' },
];
---

<header class="site-header">
  <div class="container header-shell">
    <div class="header-inner" data-header>
      <a class="brand" href={`${import.meta.env.BASE_URL}`} aria-label="Moment D.Art accueil" set:html={logoSvg}></a>
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu" data-menu-toggle>
        <span></span>
        <span></span>
        <span></span>
        <span class="sr-only">Ouvrir le menu</span>
      </button>

      <nav id="site-menu" class="site-nav" data-menu>
        <ul>
          <li><a href={`${import.meta.env.BASE_URL}`}>Accueil</a></li>

          <li class="has-dropdown" data-dropdown>
            <button type="button" class="nav-trigger" aria-expanded="false" data-dropdown-trigger>
              <span>Services</span>
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <path
                  d="M5.25 7.5 10 12.25 14.75 7.5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </button>

            <div class="dropdown" data-dropdown-panel>
              <a class="dropdown-overview" href={`${import.meta.env.BASE_URL}/services`}>Voir tous les services</a>
              {serviceItems.map((item) => (
                <a href={item.href}>{item.label}</a>
              ))}
            </div>
          </li>

          <li><a href={`${import.meta.env.BASE_URL}/realisations`}>Réalisations</a></li>
          <li><a href={`${import.meta.env.BASE_URL}/devis`}>Devis</a></li>
          <li><a href={`${import.meta.env.BASE_URL}#methode`}>Méthode</a></li>
          <li><a href={`${import.meta.env.BASE_URL}#contact`}>Contact</a></li>
        </ul>
      </nav>

      <a class="btn btn-primary quote-btn" href={`${import.meta.env.BASE_URL}devis`}>Demander un devis</a>
    </div>
  </div>
</header>

<div class="mobile-header-spacer" aria-hidden="true"></div>

<script>
  const siteHeader = document.querySelector('.site-header');
  const header = document.querySelector('[data-header]');
  const menuToggle = document.querySelector('[data-menu-toggle]');
  const menu = document.querySelector('[data-menu]');
  const dropdown = document.querySelector('[data-dropdown]');
  const dropdownTrigger = document.querySelector('[data-dropdown-trigger]');

  let lastScrollY = window.scrollY;

  const updateHeaderScrollState = () => {
    if (!header || !siteHeader) return;

    const currentScrollY = window.scrollY;
    const delta = currentScrollY - lastScrollY;
    const isMobile = window.innerWidth <= 980;


    if (isMobile) {
      if (header.classList.contains('menu-open')) {
        siteHeader.classList.remove('is-hidden');
      } else if (delta > 8 && currentScrollY > 90) {
        siteHeader.classList.add('is-hidden');
      } else if (delta < -8 || currentScrollY <= 90) {
        siteHeader.classList.remove('is-hidden');
      }
    } else {
      siteHeader.classList.remove('is-hidden');
    }

    lastScrollY = currentScrollY;
  };

  const closeMobileMenu = () => {
    if (!header || window.innerWidth > 980) return;
    header.classList.remove('menu-open');
    dropdown?.classList.remove('open');
    menuToggle?.setAttribute('aria-expanded', 'false');
    dropdownTrigger?.setAttribute('aria-expanded', 'false');
    siteHeader?.classList.remove('is-hidden');
  };

  menuToggle?.addEventListener('click', () => {
    const isOpen = header?.classList.toggle('menu-open');
    menuToggle?.setAttribute('aria-expanded', String(Boolean(isOpen)));

    if (isOpen) {
      siteHeader?.classList.remove('is-hidden');
    }
  });

  dropdownTrigger?.addEventListener('click', () => {
    if (window.innerWidth > 980) return;
    const isOpen = dropdown?.classList.toggle('open');
    dropdownTrigger?.setAttribute('aria-expanded', String(Boolean(isOpen)));
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 980) {
      header?.classList.remove('menu-open');
      dropdown?.classList.remove('open');
      menuToggle?.setAttribute('aria-expanded', 'false');
      dropdownTrigger?.setAttribute('aria-expanded', 'false');
    }

    siteHeader?.classList.remove('is-hidden');
    lastScrollY = window.scrollY;
    updateHeaderScrollState();
  });

  window.addEventListener('scroll', updateHeaderScrollState, { passive: true });
  updateHeaderScrollState();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 1rem 0 0;
    transition: transform 0.28s ease, opacity 0.28s ease;
  }

  .site-header.is-hidden {
    transform: translateY(calc(-100% - 1.5rem));
    opacity: 0;
    pointer-events: none;
  }

  .mobile-header-spacer {
    display: none;
  }

  .header-shell {
    position: relative;
  }

  .header-inner {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    padding: 0.9rem 1.15rem;
    border-radius: 999px;
    background: #f7f3ec;
    border: 1px solid transparent;
    backdrop-filter: blur(0px);
    box-shadow: none;
    transition:
      background 0.35s ease,
      border-color 0.35s ease,
      box-shadow 0.35s ease,
      backdrop-filter 0.35s ease,
      transform 0.35s ease;
  }

.brand {
  position: relative;
  z-index: 2;
  color: #241d17;
  display: block;
  width: 100%;
  max-width: 500px;
}

.brand :global(svg) {
  width: 100%;
  height: auto;
  display: block;
}

  .site-nav ul {
    display: flex;
    justify-content: center;
    gap: 1.3rem;
    list-style: none;
    padding: 0;
    margin: 0;
    align-items: center;
  }

  .site-nav a,
  .nav-trigger {
    color: #7A5C3E;
    font-weight: 600;
    position: relative;
    background: none;
    border: 0;
    padding: 0;
    font: inherit;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .site-nav a::after,
  .nav-trigger::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.38rem;
    width: 100%;
    height: 1px;
    background: color-mix(in srgb, var(--accent) 65%, transparent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .site-nav a:hover,
  .site-nav a:focus-visible,
  .nav-trigger:hover,
  .nav-trigger:focus-visible {
    color: #3E2C1C;
  }

  .site-nav a:hover::after,
  .site-nav a:focus-visible::after,
  .nav-trigger:hover::after,
  .nav-trigger:focus-visible::after,
  .has-dropdown:hover .nav-trigger::after,
  .has-dropdown:focus-within .nav-trigger::after {
    transform: scaleX(1);
  }

  .nav-trigger svg {
    width: 0.95rem;
    flex: 0 0 auto;
    transform-origin: center;
    transition: transform 0.25s ease;
  }

  .has-dropdown:hover .nav-trigger svg,
  .has-dropdown:focus-within .nav-trigger svg,
  .has-dropdown.open .nav-trigger svg {
    transform: rotate(180deg);
  }

  .has-dropdown {
    position: relative;
    padding-bottom: 1.35rem;
    margin-bottom: -1.35rem;
  }

  .has-dropdown::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    height: 18px;
  }

  .dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    min-width: 340px;
    padding: 0.8rem;
    display: grid;
    gap: 0.35rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
    background: #f7f3ec;
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 20px;
    box-shadow: 0 20px 40px rgba(23, 22, 20, 0.12);
    backdrop-filter: blur(18px);
  }

  .dropdown a {
    padding: 0.78rem 0.9rem;
    border-radius: 14px;
    color: var(--muted);
  }

  .dropdown a:hover,
  .dropdown a:focus-visible {
    background: rgba(255, 255, 255, 0.66);
    color: var(--text);
  }

  .dropdown-overview {
    color: var(--text) !important;
    border-bottom: 1px solid var(--line);
    margin-bottom: 0.15rem;
  }

  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown,
  .has-dropdown.open .dropdown {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .quote-btn {
    white-space: nowrap;
  }

  .menu-toggle,
  .sr-only {
    display: none;
  }

  @media (max-width: 1100px) {
    .header-inner {
      grid-template-columns: 220px minmax(0, 1fr) auto;
    }

    .site-nav ul {
      gap: 1rem;
    }
  }

  @media (max-width: 980px) {
    .site-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      padding: 0.55rem 0 0;
      will-change: transform;
    }

    .mobile-header-spacer {
      display: block;
      height: 92px;
    }

    .header-shell {
      min-height: 76px;
    }

    .header-inner {
      grid-template-columns: 1fr auto 1fr;
      border-radius: 24px;
      align-items: center;
      padding: 0.85rem 0.9rem;
      background: #f7f3ec;
      border: 1px solid rgba(255,255,255,0.52);
      backdrop-filter: blur(16px);
      box-shadow: 0 10px 24px rgba(23,22,20,0.045);
      row-gap: 0;
    }

    .brand {
      grid-column: 2;
      justify-self: center;
      max-width: 198px;
    }

    .quote-btn {
      display: none;
    }

    .menu-toggle {
      grid-column: 3;
      justify-self: end;
      display: inline-flex;
      flex-direction: column;
      justify-content: center;
      gap: 0.28rem;
      width: 44px;
      height: 44px;
      border-radius: 999px;
      border: 1px solid rgba(122, 92, 62, 0.14);
      background: rgba(255, 255, 255, 0.28);
      padding: 0 0.75rem;
      cursor: pointer;
      transition: background 0.25s ease, border-color 0.25s ease;
    }

    .menu-toggle span {
      display: block;
      height: 1.5px;
      background: #241d17;
      border-radius: 999px;
      transition: transform 0.25s ease, opacity 0.25s ease;
    }

    .menu-toggle .sr-only {
      display: inline;
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
    }

    .header-inner.menu-open .menu-toggle span:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }

    .header-inner.menu-open .menu-toggle span:nth-child(2) {
      opacity: 0;
    }

    .header-inner.menu-open .menu-toggle span:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }

    .site-nav {
      grid-column: 1 / -1;
      width: 100%;
      display: none;
      padding-top: 1rem;
      border-top: 1px solid rgba(122, 92, 62, 0.10);
      margin-top: 0.9rem;
    }

    .header-inner.menu-open .site-nav {
      display: block;
    }

    .site-nav ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0.15rem;
      width: 100%;
    }

    .site-nav li {
      width: 100%;
      min-width: 0;
      margin: 0;
      padding: 0;
    }

    .site-nav a,
    .nav-trigger {
      width: 100%;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 0.15rem;
      color: #241d17;
      font-size: 1rem;
    }

    .nav-trigger span {
      flex: 1 1 auto;
      text-align: left;
    }

    .nav-trigger svg {
      width: 1rem;
      margin-left: 0.75rem;
      transform-origin: center;
      transition: transform 0.25s ease;
    }

    .has-dropdown.open .nav-trigger svg {
      transform: rotate(180deg);
    }

    .site-nav a::after,
    .nav-trigger::after {
      display: none;
    }

    .has-dropdown {
      width: 100%;
      padding-bottom: 0;
      margin-bottom: 0;
    }

    .has-dropdown::after {
      display: none;
    }

    .dropdown {
      position: static;
      inset: auto;
      transform: none !important;
      opacity: 1;
      pointer-events: auto;
      min-width: 0;
      width: 100%;
      max-width: 100%;
      margin: 0;
      padding: 0.4rem 0 0.25rem 0;
      display: none;
      gap: 0.45rem;
      box-shadow: none;
      background: transparent;
      border: 0;
      border-radius: 0;
      backdrop-filter: none;
    }

    .has-dropdown.open .dropdown {
      display: grid;
    }

    .dropdown a {
      display: block;
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
      margin: 0;
      padding: 0.9rem 1rem;
      background: rgba(255, 255, 255, 0.48);
      color: #241d17;
      border-radius: 14px;
      border: 1px solid rgba(122, 92, 62, 0.08);
    }

    .dropdown a:hover,
    .dropdown a:focus-visible {
      background: rgba(255, 255, 255, 0.62);
      color: #241d17;
    }

    .dropdown-overview {
      border-bottom: 0;
      margin-bottom: 0;
      color: #241d17 !important;
    }
  }

  @media (max-width: 560px) {
    .site-header {
      padding-top: 0.45rem;
    }

    .mobile-header-spacer {
      height: 84px;
    }

    .header-shell {
      min-height: 72px;
    }

    .header-inner {
      padding: 0.8rem 0.8rem;
      border-radius: 22px;
    }

    .brand {
      max-width: 180px;
    }

    .menu-toggle {
      width: 42px;
      height: 42px;
    }

    .site-nav a,
    .nav-trigger {
      padding: 0.9rem 0.1rem;
      font-size: 0.98rem;
    }

    .dropdown a {
      padding: 0.82rem 0.9rem;
      font-size: 0.96rem;
    }
  }
</style>