---
// Layout des pages locales /zones-intervention/<ville>.
// Fournit : Header, fil d'Ariane (+ BreadcrumbList), hero avec H1 local, FAQ locale (+ FAQPage),
// CTA devis (QuoteSection) et Footer. Le contenu unique de chaque ville passe dans le slot.
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Faq from '../components/Faq.astro';
import QuoteSection from '../components/QuoteSection.astro';
import Footer from '../components/Footer.astro';

interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  title: string;
  description: string;
  zoneName: string;
  heroTitle: string;
  heroLead: string;
  faq: FaqItem[];
}

const { title, description, zoneName, heroTitle, heroLead, faq } = Astro.props as Props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description}>
  <Header />

  <Breadcrumb items={[
    { label: 'Accueil', href: base },
    { label: "Zones d'intervention", href: `${base}zones-intervention` },
    { label: zoneName },
  ]} />

  <section class="page-hero">
    <div class="container">
      <div class="card zone-hero">
        <span class="eyebrow">Zone d'intervention</span>
        <h1>{heroTitle}</h1>
        <p class="lead">{heroLead}</p>
        <div class="btn-row" style="margin-top:0.5rem;">
          <a class="btn btn-primary" href={`${base}devis`}>Demander un devis</a>
          <a class="btn btn-secondary" href={`${base}realisations`}>Voir nos réalisations</a>
        </div>
      </div>
    </div>
  </section>

  <div class="zone-page">
    <slot />
  </div>

  <Faq
    items={faq}
    eyebrow="FAQ locale"
    title={`FAQ — Peintre à ${zoneName}`}
    lead={`Les questions les plus fréquentes avant de lancer un chantier à ${zoneName}.`}
  />

  <QuoteSection />
  <Footer />
</BaseLayout>

<style>
  .zone-hero {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: flex-start;
  }

  @media (max-width: 640px) {
    .zone-hero {
      padding: 2rem 1.5rem;
    }
  }
</style>

<style is:global>
  /* Blocs partagés par les pages zones (préfixés .zone-page pour rester locaux). */
  .zone-page .zp-alt {
    background: linear-gradient(180deg, rgba(240, 233, 223, 0.55), rgba(246, 242, 235, 0));
  }

  .zone-page .zp-split {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .zone-page .zp-split h2 {
    margin-bottom: 1.25rem;
  }

  .zone-page .zp-text p + p {
    margin-top: 1.1rem;
  }

  .zone-page .zp-text a,
  .zone-page .zp-card p a {
    color: #7A5C3E;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .zone-page .zp-text a:hover,
  .zone-page .zp-card p a:hover {
    color: #3E2C1C;
  }

  .zone-page .zp-card {
    padding: 1.75rem;
  }

  .zone-page .zp-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .zone-page .zp-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .zone-page .zp-list li {
    position: relative;
    padding-left: 1.35rem;
    font-size: 0.94rem;
    line-height: 1.65;
    color: var(--muted);
  }

  .zone-page .zp-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .zone-page .zp-services {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }

  .zone-page .zp-service-card {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .zone-page .zp-service-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 28px 64px rgba(36, 29, 23, 0.12);
  }

  .zone-page .zp-service-card h3 {
    font-size: 1.1rem;
    color: var(--text);
  }

  .zone-page .zp-service-card p {
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .zone-page .zp-service-card .zp-more {
    margin-top: auto;
    padding-top: 0.5rem;
    font-size: 0.84rem;
    font-weight: 700;
    color: #7A5C3E;
  }

  .zone-page .zp-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .zone-page .zp-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    border: 1.5px solid rgba(122, 92, 62, 0.35);
    color: #7A5C3E;
    font-size: 0.86rem;
    font-weight: 600;
  }

  .zone-page a.zp-chip:hover {
    border-color: #7A5C3E;
    background: rgba(122, 92, 62, 0.06);
  }

  .zone-page span.zp-chip {
    border-style: dashed;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .zone-page .zp-split {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .zone-page .zp-services {
      grid-template-columns: 1fr;
    }
  }
</style>
