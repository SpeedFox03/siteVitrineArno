---
import { logoSvg } from '../utils/icons';
const base = import.meta.env.BASE_URL;
---

<footer class="section footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a class="brand" href={`${import.meta.env.BASE_URL}`} aria-label="Moment D.Art accueil" set:html={logoSvg}></a>
      <p>Moment D.Art · Rue des Moges · 4120 Neupré</p>
      <p class="footer-zone"><strong>Zone d'intervention :</strong> région liégeoise principalement : Neupré, Liège, Sprimont, Embourg, Beaufays. Déplacements possibles en Wallonie, Waterloo, Uccle et Vilvoorde.</p>
    </div>

    <div class="footer-links">
      <a href={`${import.meta.env.BASE_URL}`}>Accueil</a>
      <a href={`${import.meta.env.BASE_URL}/services`}>Services</a>
      <a href={`${import.meta.env.BASE_URL}/realisations`}>Réalisations</a>
      <a href={`${import.meta.env.BASE_URL}/a-propos`}>À propos</a>
      <a href={`${import.meta.env.BASE_URL}/devis`}>Devis</a>
      <a href={`${import.meta.env.BASE_URL}/mentions-legales`}>Mentions légales</a>
    </div>
  </div>
</footer>

<style>
  .brand {
    position: relative;
    z-index: 2;
    color: #241d17;
    display: block;
    width: 100%;
    max-width: 500px;
  }

  .brand :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }
  .footer {
    padding-top: 2rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid var(--line);
    padding-top: 2rem;
  }

  .footer-brand {
    max-width: 36rem;
  }

  .footer-brand p {
    margin-top: 0.5rem;
    font-size: 0.9rem;
  }

  .footer-zone {
    font-size: 0.82rem !important;
    color: var(--muted-2);
    margin-top: 0.25rem !important;
  }

  .footer-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: flex-start;
  }

  .footer-links a {
    color: #7A5C3E;
    position: relative;
    transition: color 0.25s ease;
  }

  .footer-links a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.28rem;
    width: 100%;
    height: 1px;
    background: rgba(122, 92, 62, 0.45);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .footer-links a:hover {
    color: #3E2C1C;
  }

  .footer-links a:hover::after {
    transform: scaleX(1);
  }

  @media (max-width: 720px) {
    .footer-inner {
      flex-direction: column;
    }
    .brand {
      max-width: 180px;
    }
  }
</style>
