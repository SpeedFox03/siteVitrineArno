---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BeforeAfterSlider from '../components/BeforeAfterSlider.astro';
import ProjetCard from '../components/ProjetCard.astro';
import QuoteSection from '../components/QuoteSection.astro';
import Footer from '../components/Footer.astro';
import { avantApresProjects } from '../data/avantApres';
import { projets, serviceLabels } from '../data/projets';
import type { ServiceSlug } from '../data/projets';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const featured = avantApresProjects.map((project) => ({
  ...project,
  beforeImage: `${base}${project.beforeImage}`,
  afterImage: `${base}${project.afterImage}`,
}));

const categories = [...new Set(projets.map(p => p.categorie))] as ServiceSlug[];
---

<BaseLayout
  title="Réalisations — Moment D.Art"
  description="Découvrez les chantiers réalisés par Moment D.Art à Neupré et en région liégeoise. Peinture intérieure, extérieure, enduits décoratifs, revêtements et boiseries — avant et après."
>
  <Header />

  <section class="page-hero">
    <div class="container">
      <div class="card" style="padding:2rem;">
        <span class="eyebrow">Réalisations</span>
        <h1>Avant / après : la preuve par les chantiers.</h1>
        <p class="lead" style="max-width:62ch;">Chaque projet est unique. Ces réalisations illustrent l'étendue des interventions de Moment D.Art — de la rénovation intérieure complète au détail de finition qui change tout.</p>
      </div>
    </div>
  </section>

  <section class="section section-galerie" id="galerie">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Galerie</span>
        <h2>Nos réalisations en images</h2>
      </div>

      <div class="filter-bar-wrap">
        <div class="filter-bar" role="tablist" aria-label="Filtrer par catégorie">
          <button class="filter-btn is-active" data-filter="all" role="tab" aria-selected="true">
            Tous <span class="count">{projets.length}</span>
          </button>
          {categories.map(cat => {
            const count = projets.filter(p => p.categorie === cat).length;
            return (
              <button class="filter-btn" data-filter={cat} role="tab" aria-selected="false">
                {serviceLabels[cat]} <span class="count">{count}</span>
              </button>
            );
          })}
        </div>
      </div>

      <div class="projets-grid" id="projets-grid">
        {projets.map(projet => (
          <div class="grid-item" data-item-category={projet.categorie}>
            <ProjetCard projet={projet} base={base} />
          </div>
        ))}
      </div>

      <div class="empty-state" id="empty-state" hidden>
        <p>Aucun projet dans cette catégorie pour le moment.</p>
      </div>
    </div>
  </section>

  <section class="section section-featured" id="avant-apres">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Avant / après</span>
        <h2>Tous les avant / après</h2>
      </div>
      <div class="featured-grid">
        {featured.map((p) => (
          <div class="featured-item">
            <BeforeAfterSlider {...p} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <QuoteSection />
  <Footer />
</BaseLayout>

<style>
  .page-hero h1 {
    margin: 0.9rem 0 1.1rem;
  }

  /* ── Avant/après grid ── */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    align-items: start;
  }

  .featured-item {
    min-width: 0;
    display: flex;
  }

  .featured-item :global(.showcase) {
    width: 100%;
  }

  .featured-grid > .featured-item:last-child:nth-child(odd) {
    grid-column: 1 / -1;
    max-width: calc(50% - 0.5rem);
    justify-self: center;
    width: 100%;
  }

  /* ── Galerie ── */
  .section-galerie {
    border-top: 1px solid var(--line);
  }

  .filter-bar-wrap {
    margin-bottom: 1.75rem;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .filter-bar-wrap::-webkit-scrollbar { display: none; }

  .filter-bar {
    display: flex;
    gap: 0.5rem;
    padding-bottom: 2px;
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    white-space: nowrap;
    padding: 0.48rem 1rem;
    border-radius: 999px;
    border: 1.5px solid var(--line-strong);
    background: transparent;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .filter-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .filter-btn.is-active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    box-shadow: 0 4px 12px rgba(177,138,104,0.32);
  }

  .count {
    font-size: 0.68rem;
    font-weight: 700;
    opacity: 0.7;
  }
  .filter-btn.is-active .count { opacity: 0.85; }

  .projets-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .grid-item {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .grid-item.is-hiding {
    opacity: 0;
    transform: scale(0.96);
    pointer-events: none;
  }

  .grid-item.is-hidden {
    display: none;
  }

  .grid-item.is-showing {
    animation: fadeIn 0.35s ease forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.96); }
    to   { opacity: 1; transform: scale(1); }
  }

  .empty-state {
    text-align: center;
    padding: 4rem 0;
    color: var(--muted);
    font-size: 1rem;
  }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }
    .featured-grid > .featured-item:last-child:nth-child(odd) {
      grid-column: auto;
      max-width: 100%;
      justify-self: stretch;
    }
  }

  @media (max-width: 960px) {
    .projets-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .projets-grid { grid-template-columns: 1fr; gap: 1rem; }
  }
</style>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.grid-item');
  const emptyState = document.getElementById('empty-state') as HTMLElement;

  let activeFilter = 'all';

  const applyFilter = (filter: string) => {
    activeFilter = filter;

    btns.forEach(btn => {
      const isActive = btn.dataset.filter === filter;
      btn.classList.toggle('is-active', isActive);
      btn.setAttribute('aria-selected', String(isActive));
    });

    const toHide: HTMLElement[] = [];
    const toShow: HTMLElement[] = [];

    items.forEach(item => {
      const matches = filter === 'all' || item.dataset.itemCategory === filter;
      if (matches) toShow.push(item);
      else toHide.push(item);
    });

    toHide.forEach(item => {
      if (item.classList.contains('is-hidden')) return;
      item.classList.add('is-hiding');
      item.addEventListener('transitionend', () => {
        item.classList.remove('is-hiding');
        item.classList.add('is-hidden');
      }, { once: true });
    });

    toShow.forEach(item => {
      item.classList.remove('is-hidden', 'is-hiding');
      item.classList.add('is-showing');
      item.addEventListener('animationend', () => item.classList.remove('is-showing'), { once: true });
    });

    emptyState.hidden = toShow.length > 0;
  };

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';
      if (filter !== activeFilter) applyFilter(filter);
    });
  });
</script>
