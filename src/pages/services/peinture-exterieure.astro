---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import QuoteSection from '../../components/QuoteSection.astro';
import ServicesNav from '../../components/ServicesNav.astro';
---
<BaseLayout
  title="Peinture extérieure — Moment D.Art"
  description="Peinture extérieure de façades, annexes et éléments de toiture à Neupré et en province de Liège. Protection durable, finition soignée, produits adaptés au climat belge."
>
  <Header />

  <section class="page-hero">
    <div class="container">
      <div class="card grid-2 hero-card">
        <div>
          <span class="eyebrow">Service</span>
          <h1>Peinture extérieure</h1>
          <p class="lead">
            Façades, annexes et éléments extérieurs protégés et remis en valeur avec des systèmes adaptés aux contraintes climatiques belges.
          </p>
        </div>
        <img
          src="https://images.unsplash.com/photo-1448630360428-65456885c650?auto=format&fit=crop&w=1400&q=80"
          alt="Peinture extérieure de façade"
          style="border-radius:22px; width:100%; height:100%; object-fit:cover; min-height:320px;"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        <div>
          <span class="eyebrow">Contexte</span>
          <h2>Quand intervenir ?</h2>
          <p class="lead">
            Une façade qui se dégrade perd d'abord en esthétique, puis en protection. Écaillage, efflorescences, fissures ou couleur passée sont des signaux qui méritent une intervention rapide pour éviter des dégâts plus profonds.
          </p>
          <p style="margin-top: 1rem;">
            Idéal pour les maisons de plus de 10 ans, les biens avant revente, ou simplement pour redonner un caractère fort à un extérieur qui a perdu son impact visuel.
          </p>
        </div>
        <div class="card detail-card">
          <h3>Ce qu'Arno fait concrètement</h3>
          <ul class="detail-list">
            <li>Inspection et diagnostic de l'état de la façade</li>
            <li>Nettoyage haute pression si nécessaire</li>
            <li>Traitement des fissures et des zones dégradées</li>
            <li>Application d'un fixateur ou primaire adapté au support</li>
            <li>Peinture minérale, silicone ou acrylique selon le mur</li>
            <li>Finition hydrofuge et résistante aux UV</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <span class="eyebrow">Supports traités</span>
      <h2>Tous types de façades</h2>
      <div class="finishes-grid">
        <div class="card finish-card">
          <h3>Enduit & crépi</h3>
          <p>Reprise des fissures, uniformisation de la surface, application d'une peinture minérale ou silicone compatible.</p>
        </div>
        <div class="card finish-card">
          <h3>Briques peintes</h3>
          <p>Décapage si nécessaire, traitement de l'humidité, peinture microporeuse pour laisser respirer le support.</p>
        </div>
        <div class="card finish-card">
          <h3>Béton & parpaing</h3>
          <p>Nettoyage, impression spécifique béton, peinture acrylique ou époxy selon l'exposition et l'usage.</p>
        </div>
      </div>
    </div>
  </section>

  <ServicesNav current="Peinture extérieure" />
  <QuoteSection />
  <Footer />
</BaseLayout>

<style>
  .hero-card > div:first-child {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.76rem;
    font-weight: 700;
  }

  .eyebrow::before {
    content: '';
    width: 42px;
    height: 1px;
    background: color-mix(in srgb, var(--accent) 55%, white);
  }

  .detail-card {
    padding: 1.5rem;
  }

  .detail-card h3 {
    margin-bottom: 1rem;
  }

  .detail-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.65rem;
  }

  .detail-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.5;
    padding-top: 0.65rem;
    border-top: 1px solid var(--line);
  }

  .detail-list li:first-child {
    border-top: none;
    padding-top: 0;
  }

  .detail-list li::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    margin-top: 0.45rem;
  }

  .section-alt {
    background: rgba(177, 138, 104, 0.04);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .finishes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .finish-card {
    padding: 1.4rem;
  }

  .finish-card h3 {
    margin-bottom: 0.6rem;
    color: var(--accent-strong);
  }

  @media (max-width: 900px) {
    .finishes-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .hero-card {
      grid-template-columns: 1fr;
    }
  }
</style>