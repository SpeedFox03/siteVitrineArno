---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BeforeAfterSlider from '../components/BeforeAfterSlider.astro';
import QuoteSection from '../components/QuoteSection.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const featured = [
  {
    meta: 'Rénovation complète · Région liégeoise',
    title: 'Grand volume remis à neuf',
    description: 'Reprise totale des murs et plafonds d\'un séjour à volumes hauts — poutre apparente relaquée, finitions blanc mat, résultat épuré et lumineux.',
    beforeImage: `${base}/images/peinture-interieure/volume-poutre-renovation-1.jpg`,
    afterImage: `${base}/images/peinture-interieure/volume-poutre-renovation-2.jpg`,
  },
  {
    meta: 'Peinture décorative · Chambre',
    title: 'Mur accent et rénovation chambre',
    description: 'Transformation d\'une chambre par un travail sur la couleur et le volume — du mur orange existant vers un rendu neutre et contemporain.',
    beforeImage: `${base}/images/peinture-interieure/chambre-renovation-avant-crop.jpg`,
    afterImage: `${base}/images/peinture-interieure/chambre-renovation-apres-crop.jpg`,
  },
  {
    meta: 'Rénovation intérieure · Pièce à vivre',
    title: 'Remise en état complète — murs et finitions',
    description: 'Pièce entièrement décapée, murs repris de zéro et repeints en teinte neutre sablée — sol refait, résultat propre et habitable.',
    beforeImage: `${base}/images/peinture-interieure/piece-renovation-avant.jpg`,
    afterImage: `${base}/images/peinture-interieure/piece-renovation-apres.jpg`,
  },
  {
    meta: 'Traitement moisissures · Mur extérieur',
    title: 'Traitement moisissures et repeinture',
    description: 'Mur envahi par les moisissures traité, assaini et repeint — surface propre, protégée contre l\'humidité et les UV.',
    beforeImage: `${base}/images/peinture-exterieure/moisissures-exterieur-avant.jpg`,
    afterImage: `${base}/images/peinture-exterieure/moisissures-exterieur-apres.jpg`,
  },
  {
    meta: 'Rénovation plafond · Salle de bain',
    title: 'Plafond salle de bain — décapage et repeinture',
    description: 'Plafond humide décapé, traité contre les champignons et repeint en blanc mat — rendu propre, net et durable en milieu humide.',
    beforeImage: `${base}/images/peinture-interieure/plafond-sdb-avant.jpg`,
    afterImage: `${base}/images/peinture-interieure/plafond-sdb-apres.jpg`,
  },
];

const gallery = [
  { category: 'interieur', label: 'Peinture intérieure', title: 'Maison Beaufays — couloir et escalier', location: 'Beaufays', image: `${base}/images/peinture-interieure/peinture-interieure-maison-beaufays.jpg` },
  { category: 'exterieur', label: 'Peinture extérieure', title: 'Façade briques peintes — maison mitoyenne', location: 'Région liégeoise', image: `${base}/images/peinture-exterieure/facade-briques-blanc.jpg` },
  { category: 'mural', label: 'Peinture décorative', title: 'Mural géométrique entrée', location: 'Région liégeoise', image: `${base}/images/revetement-mural/peinture-decorative-entree.jpg` },
  { category: 'mural', label: 'Peinture décorative', title: 'Géométrique vert foncé — chambre', location: 'Région liégeoise', image: `${base}/images/revetement-mural/peinture-geometrique-vert-fonce.jpg` },
  { category: 'enduits', label: 'Enduits décoratifs', title: 'Mur bleu texturé — finition décorative', location: 'Région liégeoise', image: `${base}/images/revetement-mural/peinture-geometrique-bleu.jpg` },
  { category: 'interieur', label: 'Peinture intérieure', title: 'Grand séjour — volumes hauts et poutre relaquée', location: 'Région liégeoise', image: `${base}/images/peinture-interieure/volume-poutre-renovation-3.jpg` },
  { category: 'interieur', label: 'Peinture intérieure', title: 'WC après rénovation — finitions blanc mat', location: 'Région liégeoise', image: `${base}/images/peinture-interieure/wc-renovation-blanc.jpg` },
  { category: 'mural', label: 'Peinture décorative', title: 'Mur accent vert sauge — chambre', location: 'Région liégeoise', image: `${base}/images/peinture-interieure/mur-accent-vert-sauge.jpg` },
  { category: 'mural', label: 'Peinture décorative', title: 'Géométrique gris-bleu — mansarde', location: 'Région liégeoise', image: `${base}/images/revetement-mural/peinture-geometrique-vert-menthe.jpg` },
];

const filters = [
  { key: 'tous', label: 'Tous' },
  { key: 'interieur', label: 'Intérieur' },
  { key: 'exterieur', label: 'Extérieur' },
  { key: 'mural', label: 'Mural' },
  { key: 'enduits', label: 'Enduits décoratifs' },
];
---

<BaseLayout
  title="Réalisations — Moment D.Art"
  description="Découvrez les chantiers réalisés par Moment D.Art à Neupré et en région liégeoise. Peinture intérieure, extérieure, enduits décoratifs, revêtements et boiseries — avant et après."
>
  <Header />

  <section class="page-hero">
    <div class="container">
      <div class="card" style="padding:2rem;">
        <span class="eyebrow">Réalisations</span>
        <h1>Avant / après : la preuve par les chantiers.</h1>
        <p class="lead" style="max-width:62ch;">Chaque projet est unique. Ces réalisations illustrent l'étendue des interventions de Moment D.Art — de la rénovation intérieure complète au détail de finition qui change tout.</p>
      </div>
    </div>
  </section>

  <section class="section section-featured" id="avant-apres">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Avant / après</span>
        <h2>Projets en vedette</h2>
      </div>
      <div class="featured-grid">
        {featured.map((p) => (
          <div class="featured-item">
            <BeforeAfterSlider {...p} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt section-gallery" id="galerie">
    <div class="container">
      <div class="gallery-head">
        <div>
          <span class="eyebrow">Galerie</span>
          <h2>Toutes les réalisations</h2>
        </div>
        <div class="filter-bar" role="group" aria-label="Filtrer par type de service">
          {filters.map((f) => (
            <button
              type="button"
              class={`filter-btn${f.key === 'tous' ? ' active' : ''}`}
              data-filter={f.key}
            >
              {f.label}
            </button>
          ))}
        </div>
      </div>

      <div class="gallery-grid" id="gallery-grid">
        {gallery.map((p) => (
          <article class="gallery-card card" data-category={p.category}>
            <div class="gallery-img-wrap">
              <img src={p.image} alt={p.title} loading="lazy" class="gallery-img" />
              <span class="category-pill">{p.label}</span>
            </div>
            <div class="gallery-info">
              <p class="gallery-location">{p.location}</p>
              <h3 class="gallery-title">{p.title}</h3>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>

  <QuoteSection />
  <Footer />
</BaseLayout>

<style>
  .page-hero h1 {
    margin: 0.9rem 0 1.1rem;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    align-items: stretch;
  }

  .featured-item {
    min-width: 0;
    height: 100%;
    display: flex;
  }

  .featured-item :global(.showcase) {
    width: 100%;
    height: 100%;
  }

  .featured-grid > .featured-item:last-child:nth-child(odd) {
    grid-column: 1 / -1;
    max-width: calc(50% - 0.5rem);
    justify-self: center;
    width: 100%;
  }

  .gallery-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .gallery-head h2 {
    margin-bottom: 0;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .filter-btn {
    padding: 0.55rem 1.1rem;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    background: transparent;
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    font-family: inherit;
  }

  .filter-btn:hover {
    background: rgba(255,255,255,0.55);
    color: var(--text);
    border-color: color-mix(in srgb, var(--accent) 35%, var(--line-strong));
  }

  .filter-btn.active {
    background: var(--accent);
    color: #faf7f2;
    border-color: var(--accent);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .gallery-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 0;
    transition: transform 0.28s ease;
  }

  .gallery-card:hover {
    transform: translateY(-3px);
  }

  .gallery-img-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .gallery-card:hover .gallery-img {
    transform: scale(1.04);
  }

  .category-pill {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: rgba(255,255,255,0.82);
    backdrop-filter: blur(8px);
    color: var(--accent-strong);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.35rem 0.72rem;
    border-radius: 999px;
    border: 1px solid rgba(23,22,20,0.06);
  }

  .gallery-info {
    padding: 1rem 1.1rem 1.2rem;
  }

  .gallery-location {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 0.3rem;
  }

  .gallery-title {
    font-size: 0.97rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.35;
  }

  .gallery-note {
    margin-top: 1.5rem;
    font-size: 0.78rem;
    color: var(--muted-2);
    text-align: center;
  }

  .gallery-card[data-hidden] {
    display: none;
  }

  .gallery-card.is-last-visible-centered {
    grid-column: 2;
  }

  @media (max-width: 900px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-head { flex-direction: column; align-items: flex-start; }

    .gallery-card.is-last-visible-centered {
      grid-column: 1 / -1;
      max-width: calc(50% - 0.5rem);
      justify-self: center;
      width: 100%;
    }
  }

  @media (max-width: 720px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }
    .featured-grid > .featured-item:last-child:nth-child(odd) {
      grid-column: auto;
      max-width: 100%;
      justify-self: stretch;
    }
  }

  @media (max-width: 560px) {
    .gallery-grid { grid-template-columns: 1fr; }
    .filter-bar { gap: 0.4rem; }
    .filter-btn { font-size: 0.8rem; padding: 0.48rem 0.9rem; }

    .gallery-card.is-last-visible-centered {
      grid-column: auto;
      max-width: 100%;
      justify-self: stretch;
    }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.gallery-card');
  const galleryGrid = document.querySelector<HTMLElement>('#gallery-grid');

  const updateLastVisibleCard = () => {
    cards.forEach((card) => card.classList.remove('is-last-visible-centered'));

    if (!galleryGrid) return;

    const visibleCards = Array.from(cards).filter((card) => !card.hasAttribute('data-hidden'));
    const columns = getComputedStyle(galleryGrid).gridTemplateColumns.split(' ').filter(Boolean).length;

    if (columns > 1 && visibleCards.length % columns === 1) {
      visibleCards[visibleCards.length - 1]?.classList.add('is-last-visible-centered');
    }
  };

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.dataset.filter;
      cards.forEach((card) => {
        if (filter === 'tous' || card.dataset.category === filter) {
          card.removeAttribute('data-hidden');
        } else {
          card.setAttribute('data-hidden', '');
        }
      });

      updateLastVisibleCard();
    });
  });

  window.addEventListener('resize', updateLastVisibleCard);
  updateLastVisibleCard();
</script>
