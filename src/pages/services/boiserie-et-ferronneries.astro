---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import QuoteSection from '../../components/QuoteSection.astro';
import ServicesNav from '../../components/ServicesNav.astro';
---
<BaseLayout
  title="Boiserie et ferronneries — Moment D.Art"
  description="Remise en peinture de boiseries, portes, châssis, garde-corps et éléments métalliques à Neupré et en province de Liège. Finitions soignées pour intérieurs premium."
>
  <Header />

  <section class="page-hero">
    <div class="container">
      <div class="card grid-2 hero-card">
        <div>
          <span class="eyebrow">Service</span>
          <h1>Boiserie & ferronneries</h1>
          <p class="lead">
            Portes, châssis, boiseries décoratives, garde-corps et éléments métalliques repris avec précision pour renforcer le standing du lieu.
          </p>
        </div>
        <img
          src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=1400&q=80"
          alt="Boiserie et ferronneries peintes avec soin"
          style="border-radius:22px; width:100%; height:100%; object-fit:cover; min-height:320px;"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        <div>
          <span class="eyebrow">Contexte</span>
          <h2>Pourquoi soigner les détails ?</h2>
          <p class="lead">
            Le bois et le métal donnent immédiatement le ton d'un intérieur. Une porte encrassée, un châssis écaillé ou un escalier terne tire vers le bas toute une rénovation par ailleurs soignée.
          </p>
          <p style="margin-top: 1rem;">
            Ces éléments sont souvent traités en dernier mais leur état final conditionne la perception globale du chantier. Un beau fini sur les boiseries fait la différence entre un résultat "propre" et un résultat "haut de gamme".
          </p>
        </div>
        <div class="card detail-card">
          <h3>Ce qu'Arno fait concrètement</h3>
          <ul class="detail-list">
            <li>Ponçage et décapage du bois ou du métal selon l'état</li>
            <li>Traitement antirouille pour les ferronneries</li>
            <li>Application d'un primaire d'accrochage adapté à la matière</li>
            <li>Deux couches de laque ou de peinture glycéro</li>
            <li>Finition mate, satinée ou brillante selon le résultat souhaité</li>
            <li>Protection des vitres et surfaces adjacentes</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <span class="eyebrow">Éléments traités</span>
      <h2>Ce qui est pris en charge</h2>
      <div class="finishes-grid">
        <div class="card finish-card">
          <h3>Boiseries intérieures</h3>
          <p>Portes, chambranles, moulures, plinthes, placards, escaliers et rampes en bois massif ou MDF.</p>
        </div>
        <div class="card finish-card">
          <h3>Châssis & volets</h3>
          <p>Fenêtres en bois, volets battants ou roulants, portes de garage : remise en état complète pour l'extérieur.</p>
        </div>
        <div class="card finish-card">
          <h3>Ferronneries</h3>
          <p>Garde-corps, rampes d'escalier, grilles, portails et éléments décoratifs en métal traités contre la corrosion.</p>
        </div>
      </div>
    </div>
  </section>

  <ServicesNav current="Boiserie & ferronneries" />
  <QuoteSection />
  <Footer />
</BaseLayout>

<style>
  .hero-card > div:first-child {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.76rem;
    font-weight: 700;
  }

  .eyebrow::before {
    content: '';
    width: 42px;
    height: 1px;
    background: color-mix(in srgb, var(--accent) 55%, white);
  }

  h2 {
    margin-bottom: 1.25rem;
    }

    

  .detail-card { padding: 1.5rem; }
  .detail-card h3 { margin-bottom: 1rem; }

  .detail-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.65rem;
  }

  .detail-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.5;
    padding-top: 0.65rem;
    border-top: 1px solid var(--line);
  }

  .detail-list li:first-child { border-top: none; padding-top: 0; }

  .detail-list li::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    margin-top: 0.45rem;
  }

  .section-alt {
    background: rgba(177, 138, 104, 0.04);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .finishes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .finish-card { padding: 1.4rem; }
  .finish-card h3 { margin-bottom: 0.6rem; color: var(--accent-strong); }

  @media (max-width: 900px) {
    .finishes-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 720px) {
    .hero-card { grid-template-columns: 1fr; }
  }
</style>