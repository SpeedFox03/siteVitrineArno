---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Nettoyage de sol — Moment D.Art"
  description="Nettoyage de sol, entretien et remise en état de surfaces au sol pour particuliers et professionnels."
>
  <Header />

  <section class="page-hero">
    <div class="container">
      <div class="card grid-2">
        <div>
          <span class="eyebrow">Service</span>
          <h1>Nettoyage de sol</h1>
          <p class="lead">
            Nettoyage et entretien des sols pour maintenir des surfaces propres, praticables et adaptées à l’usage quotidien.
          </p>
        </div>

        <img
          src="https://images.unsplash.com/photo-1484154218962-a197022b5858?auto=format&fit=crop&w=1400&q=80"
          alt="Nettoyage de sol"
          style="border-radius:22px; width:100%; height:100%; object-fit:cover; min-height:320px;"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid-2">
        <div>
          <h2>Un entretien adapté aux surfaces au sol</h2>
          <p class="lead">
            Le nettoyage de sol s’intègre aussi bien dans l’entretien régulier que dans les opérations de remise en état après usage intensif ou occupation.
          </p>
        </div>

        <div class="card" style="padding:1.5rem;">
          <h3>Résultat recherché</h3>
          <p>
            Un sol propre, entretenu et fonctionnel, compatible avec les besoins des espaces privés comme professionnels.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>