---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout title="Peinture industrielle et époxy — Moment D.Art">
  <Header />
  <section class="page-hero">
    <div class="container">
      <div class="card grid-2">
        <div>
          <span class="eyebrow">Service</span>
          <h1>Peinture industrielle et époxy</h1>
          <p class="lead">Traitements techniques pour locaux professionnels, surfaces sollicitées et environnements nécessitant une finition résistante, propre et durable.</p>
        </div>
        <img src="https://images.unsplash.com/photo-1513694203232-719a280e022f?auto=format&fit=crop&w=1400&q=80" alt="Peinture industrielle et époxy" style="border-radius:22px; width:100%; height:100%; object-fit:cover; min-height:320px;" />
      </div>
    </div>
  </section>
  <section class="section"><div class="container"><div class="grid-2"><div><h2>Des solutions pensées pour la résistance</h2><p class="lead">La peinture industrielle et les systèmes époxy conviennent aux espaces techniques, ateliers, circulations, garages et zones où la tenue dans le temps est essentielle.</p></div><div class="card" style="padding:1.5rem;"><h3>Applications</h3><p>Sols, murs, supports techniques et éléments soumis à l’usure avec une approche adaptée aux contraintes du lieu et à l’usage quotidien.</p></div></div></div></section>
  <Footer />
</BaseLayout>
