---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import QuoteSection from '../components/QuoteSection.astro';
import ServicesNav from '../components/ServicesNav.astro';

interface Props {
  title: string;
  description: string;
  heroTitle: string;
  heroLead: string;
  heroImage: string;
  heroImageAlt: string;
  current: string;
}

const { title, description, heroTitle, heroLead, heroImage, heroImageAlt, current } = Astro.props;
---
<BaseLayout {title} {description}>
  <Header />

  <section class="page-hero">
    <div class="container">
      <div class="card grid-2 hero-card">
        <div class="hero-text">
          <span class="eyebrow">Service</span>
          <h1>{heroTitle}</h1>
          <p class="lead">{heroLead}</p>
        </div>
        <img
          src={heroImage}
          alt={heroImageAlt}
          class="hero-img"
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <slot name="context" />
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <slot name="cards" />
    </div>
  </section>

  <ServicesNav current={current} />
  <QuoteSection />
  <Footer />
</BaseLayout>

<style is:global>
  .hero-text {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  .hero-img {
    border-radius: 22px;
    width: 100%;
    height: 100%;
    object-fit: cover;
    min-height: 320px;
  }

  .section h2 {
    margin-bottom: 1.25rem;
  }

  .detail-card {
    padding: 1.5rem;
  }

  .detail-card h3 {
    margin-bottom: 1rem;
  }

  .detail-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.65rem;
  }

  .detail-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.5;
    padding-top: 0.65rem;
    border-top: 1px solid var(--line);
  }

  .detail-list li:first-child {
    border-top: none;
    padding-top: 0;
  }

  .detail-list li::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    margin-top: 0.45rem;
  }

  .section-alt {
    background: rgba(177, 138, 104, 0.04);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .finishes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .finish-card {
    padding: 1.4rem;
  }

  .finish-card h3 {
    margin-bottom: 0.6rem;
    color: var(--accent-strong);
  }

  @media (max-width: 900px) {
    .finishes-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .hero-card {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .hero-text {
      padding: 1.4rem;
    }

    .detail-card {
      padding: 1.2rem;
    }

    .finish-card {
      padding: 1.1rem;
    }
  }
</style>
