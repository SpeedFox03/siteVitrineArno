---
interface Props {
  title: string;
  description: string;
  meta: string;
  beforeLabel?: string;
  afterLabel?: string;
  beforeImage: string;
  afterImage: string;
}

const {
  title,
  description,
  meta,
  beforeLabel = 'Avant',
  afterLabel = 'Après',
  beforeImage,
  afterImage,
} = Astro.props;
---

<article class="showcase card">
  <div class="showcase-head">
    <div>
      <p class="meta">{meta}</p>
      <h3>{title}</h3>
    </div>
  </div>

  <div class="ba-slider" data-ba-slider>
    <img src={beforeImage} alt={`${title} - ${beforeLabel}`} class="base-image" loading="lazy" />

    <div class="overlay" style="clip-path: inset(0 50% 0 0);">
      <img src={afterImage} alt={`${title} - ${afterLabel}`} class="overlay-image" loading="lazy" />
    </div>

    <div class="labels">
      <span>{beforeLabel}</span>
      <span>{afterLabel}</span>
    </div>

    <input aria-label={`Comparer ${beforeLabel} et ${afterLabel}`} type="range" min="0" max="100" value="50" />

    <div class="divider" style="left: 50%;">
      <div class="handle"></div>
    </div>
  </div>
</article>

<style>
  .showcase {
    padding: 1rem;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 1rem;
    height: 100%;
    background: var(--surface-strong);
    position: relative;
    overflow: hidden;
  }

  .showcase::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.22), rgba(255,255,255,0.03) 40%, transparent 65%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .showcase:hover::before {
    opacity: 1;
  }

  .showcase-head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-items: start;
  }

  .showcase-head > div,
  .showcase-head > p {
    margin: 0;
  }

  .showcase-head h3 {
    margin: 0;
  }

  .meta {
    margin-bottom: 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--accent);
  }

  .ba-slider {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    width: 100%;
    background: #ece4d8;
    border: 1px solid rgba(23,22,20,0.08);
  }

  .ba-slider::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(18,13,8,0.04), transparent 30%, rgba(18,13,8,0.12));
    pointer-events: none;
  }

  .ba-slider img {
    user-select: none;
    pointer-events: none;
  }

  .base-image,
  .overlay-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .base-image {
    filter: grayscale(0.18) saturate(0.7) brightness(0.96);
  }

  .overlay {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 1;
  }

  .overlay::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    width: 1px;
    background: rgba(255,255,255,0.85);
    pointer-events: none;
  }

  .overlay-image {
    filter: saturate(0.95) contrast(1.02);
  }

  .labels {
    position: absolute;
    left: 1rem;
    right: 1rem;
    top: 1rem;
    display: flex;
    justify-content: space-between;
    pointer-events: none;
    z-index: 2;
  }

  .labels span {
    background: rgba(255,255,255,0.78);
    color: var(--text);
    padding: 0.45rem 0.72rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(23,22,20,0.06);
    box-shadow: 0 8px 18px rgba(23,22,20,0.07);
  }

  .ba-slider input[type='range'] {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: ew-resize;
    margin: 0;
    z-index: 3;
  }

  .divider {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 0;
    pointer-events: none;
    z-index: 2;
  }

  .divider::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 1px;
    background: rgba(255,255,255,0.95);
    box-shadow: 0 0 0 1px rgba(23,22,20,0.08);
  }

  .handle {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: rgba(255,255,255,0.9);
    box-shadow: 0 16px 30px rgba(23,22,20,0.14);
    border: 1px solid rgba(23,22,20,0.08);
  }

  .handle::before,
  .handle::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 9px;
    height: 9px;
    border-top: 1.5px solid var(--text);
    border-right: 1.5px solid var(--text);
  }

  .handle::before {
    left: 17px;
    transform: translateY(-50%) rotate(-135deg);
  }

  .handle::after {
    right: 17px;
    transform: translateY(-50%) rotate(45deg);
  }

  @media (max-width: 860px) {
    .showcase {
      padding: 0.9rem;
      gap: 0.85rem;
    }

    .showcase-head {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .ba-slider {
      border-radius: 20px;
    }

    .labels {
      left: 0.8rem;
      right: 0.8rem;
      top: 0.8rem;
    }

    .labels span {
      padding: 0.38rem 0.62rem;
      font-size: 0.72rem;
    }

    .handle {
      width: 48px;
      height: 48px;
    }

    .handle::before,
    .handle::after {
      width: 8px;
      height: 8px;
    }

    .handle::before {
      left: 14px;
    }

    .handle::after {
      right: 14px;
    }
  }

  @media (max-width: 560px) {
    .showcase {
      padding: 0.8rem;
      gap: 0.75rem;
      border-radius: 22px;
    }

    .meta {
      font-size: 0.68rem;
      margin-bottom: 0.3rem;
    }

    .showcase-head h3 {
      font-size: 1.05rem;
      line-height: 1.15;
    }

    .ba-slider {
      border-radius: 18px;
      aspect-ratio: 4 / 3;
    }

    .labels {
      left: 0.7rem;
      right: 0.7rem;
      top: 0.7rem;
    }

    .labels span {
      padding: 0.34rem 0.56rem;
      font-size: 0.68rem;
    }

    .handle {
      width: 44px;
      height: 44px;
    }

    .handle::before {
      left: 13px;
    }

    .handle::after {
      right: 13px;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-ba-slider]').forEach((slider) => {
    const input = slider.querySelector('input');
    const overlay = slider.querySelector('.overlay');
    const divider = slider.querySelector('.divider');

    const update = () => {
      const value = Number(input.value);
      overlay.style.clipPath = `inset(0 ${100 - value}% 0 0)`;
      divider.style.left = `${value}%`;
    };

    input.addEventListener('input', update);
    update();
  });
</script>