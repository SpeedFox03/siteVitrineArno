<section class="section" id="methode" data-method-section>
  <div class="container">
    <div class="section-header method-reveal-head" data-method-reveal>
      <span class="eyebrow">Méthode</span>
      <h2>Une organisation claire pour l’entretien et le nettoyage des bâtiments.</h2>
    </div>

    <div class="grid-steps">
      <article class="card step method-reveal-card" data-method-reveal style="--reveal-delay: 0.12s;">
        <span class="number">I</span>
        <h3>Visite et analyse</h3>
        <p>Évaluation des lieux, de l’usage des espaces, de l’état des surfaces et des contraintes techniques d’intervention.</p>
      </article>

      <article class="card step method-reveal-card is-offset" data-method-reveal style="--reveal-delay: 0.24s;">
        <span class="number">II</span>
        <h3>Devis et plan d’intervention</h3>
        <p>Chiffrage clair, définition des prestations de nettoyage, des moyens à prévoir et du niveau de remise en état attendu.</p>
      </article>

      <article class="card step method-reveal-card" data-method-reveal style="--reveal-delay: 0.36s;">
        <span class="number">III</span>
        <h3>Préparation des zones</h3>
        <p>Protection des espaces, organisation du chantier et préparation des surfaces avant nettoyage ou entretien approfondi.</p>
      </article>

      <article class="card step method-reveal-card is-offset" data-method-reveal style="--reveal-delay: 0.48s;">
        <span class="number">IV</span>
        <h3>Intervention et contrôle</h3>
        <p>Réalisation du nettoyage, vérification du résultat et remise en état propre des lieux en fin d’intervention.</p>
      </article>
    </div>
  </div>
</section>

<style>
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.74rem;
    font-weight: 700;
    color: #7A5C3E;
  }

  .eyebrow::before {
    content: '';
    width: 28px;
    height: 1px;
    background: rgba(122, 92, 62, 0.42);
  }

  .grid-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    align-items: start;
  }

  .step.is-offset {
    margin-top: 50%;
  }

  .step {
    padding: 1.4rem;
    display: grid;
    gap: 0.8rem;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease,
      border-color 0.35s ease;
  }

  .step::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.22), rgba(255,255,255,0.04) 35%, transparent 65%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .step:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 30px rgba(23, 22, 20, 0.08);
    border-color: rgba(176, 141, 87, 0.28);
  }

  .step:hover::before {
    opacity: 1;
  }

  .method-reveal-head,
  .method-reveal-card {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.85s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0s);
    will-change: opacity, transform;
  }

  .method-reveal-head.is-visible,
  .method-reveal-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .method-reveal-head {
    --reveal-delay: 0s;
  }

  @media (prefers-reduced-motion: reduce) {
    .method-reveal-head,
    .method-reveal-card {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .step {
      transition: none;
    }

    .step:hover {
      transform: none;
      box-shadow: none;
    }

    .step::before {
      display: none;
    }
  }

  @media (max-width: 980px) {
    .grid-steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 720px) {
    .grid-steps {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const methodSection = document.querySelector('[data-method-section]');

  if (methodSection && typeof window !== 'undefined') {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const items = methodSection.querySelectorAll('[data-method-reveal]');

    if (prefersReducedMotion) {
      items.forEach((item) => item.classList.add('is-visible'));
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              setTimeout(() => {
                items.forEach((item) => item.classList.add('is-visible'));
              }, 180);

              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.18,
          rootMargin: '0px 0px -8% 0px',
        }
      );

      observer.observe(methodSection);
    }
  }
</script>