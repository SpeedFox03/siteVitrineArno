---
const services = [
  { href: '/services/peinture-interieure', title: 'Peinture intérieure', text: 'Murs, plafonds, cages d’escalier et espaces de vie traités avec précision pour un rendu net, lumineux et durable.' },
  { href: '/services/peinture-exterieure', title: 'Peinture extérieure', text: 'Façades, annexes et éléments extérieurs protégés avec des produits adaptés et une finition durable.' },
  { href: '/services/peinture-industrielle-et-epoxy', title: 'Peinture industrielle et époxy', text: 'Solutions techniques pour ateliers, locaux professionnels, supports sollicités et finitions nécessitant une forte résistance.' },
  { href: '/services/revetement-de-sol', title: 'Revêtement de sol', text: 'Habillage et rénovation des sols pour apporter résistance, confort visuel et cohérence avec l’ensemble du projet.' },
  { href: '/services/revetement-mural', title: 'Revêtement mural', text: 'Pose de papiers peints, textures murales et finitions décoratives élégantes.' },
  { href: '/services/boiserie-et-ferronneries', title: 'Boiserie et ferronneries', text: 'Portes, châssis, boiseries et éléments métalliques remis en valeur dans un esprit soigné et haut de gamme.' },
];
---

<section class="section" id="services-apercu" data-services-section>
  <div class="container">
    <div class="section-header services-reveal-head" data-services-reveal>
      <span class="eyebrow">Services</span>
      <h2>Une offre complète, pensée pour des lieux exigeants.</h2>
      <p class="lead">Chaque prestation possède sa propre page de service pour détailler les usages, les finitions et les typologies de projets concernés.</p>
    </div>

    <div class="service-grid">
      {services.map((service, index) => {
        const icons = [
          // Peinture intérieure
        `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M232,32a8,8,0,0,0-8-8c-44.08,0-89.31,49.71-114.43,82.63A60,60,0,0,0,32,164c0,30.88-19.54,44.73-20.47,45.37A8,8,0,0,0,16,224H92a60,60,0,0,0,57.37-77.57C182.3,121.31,232,76.08,232,32ZM92,208H34.63C41.38,198.41,48,183.92,48,164a44,44,0,1,1,44,44Zm32.42-94.45q5.14-6.66,10.09-12.55A76.23,76.23,0,0,1,155,121.49q-5.9,4.94-12.55,10.09A60.54,60.54,0,0,0,124.42,113.55Zm42.7-2.68a92.57,92.57,0,0,0-22-22c31.78-34.53,55.75-45,69.9-47.91C212.17,55.12,201.65,79.09,167.12,110.87Z"></path></svg>`,

          // Peinture extérieure  
        `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M224,48H32a8,8,0,0,0-8,8V200a8,8,0,0,0,8,8H224a8,8,0,0,0,8-8V56A8,8,0,0,0,224,48ZM88,144V112h80v32Zm-48,0V112H72v32Zm144-32h32v32H184Zm32-16H136V64h80ZM120,64V96H40V64ZM40,160h80v32H40Zm96,32V160h80v32Z"></path></svg>`,
          // Peinture industrielle et époxy
        `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M234.53,139.07a8,8,0,0,0,3.13-13.24L122.17,10.34a8,8,0,0,0-11.31,0L70.25,51,45.65,26.34A8,8,0,0,0,34.34,37.66l24.6,24.6L15,106.17a24,24,0,0,0,0,33.94L99.89,225a24,24,0,0,0,33.94,0l78.49-78.49Zm-32.19-5.24-79.83,79.83a8,8,0,0,1-11.31,0L26.34,128.8a8,8,0,0,1,0-11.31L70.25,73.57l29.12,29.12a28,28,0,1,0,11.31-11.32L81.57,62.26l35-34.95L217.19,128l-11.72,3.9A8.09,8.09,0,0,0,202.34,133.83Zm-86.83-26.31,0,0a13.26,13.26,0,1,1-.05.06S115.51,107.53,115.51,107.52Zm123.15,56a8,8,0,0,0-13.32,0C223.57,166.23,208,190.09,208,208a24,24,0,0,0,48,0C256,190.09,240.43,166.23,238.66,163.56ZM232,216a8,8,0,0,1-8-8c0-6.8,4-16.32,8-24.08,4,7.76,8,17.34,8,24.08A8,8,0,0,1,232,216Z"></path></svg>`,
          // Revêtement de sol
        `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M104,40H56A16,16,0,0,0,40,56v48a16,16,0,0,0,16,16h48a16,16,0,0,0,16-16V56A16,16,0,0,0,104,40Zm0,64H56V56h48v48Zm96-64H152a16,16,0,0,0-16,16v48a16,16,0,0,0,16,16h48a16,16,0,0,0,16-16V56A16,16,0,0,0,200,40Zm0,64H152V56h48v48Zm-96,32H56a16,16,0,0,0-16,16v48a16,16,0,0,0,16,16h48a16,16,0,0,0,16-16V152A16,16,0,0,0,104,136Zm0,64H56V152h48v48Zm96-64H152a16,16,0,0,0-16,16v48a16,16,0,0,0,16,16h48a16,16,0,0,0,16-16V152A16,16,0,0,0,200,136Zm0,64H152V152h48v48Z"></path></svg>`,

          // Revêtement mural
        `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M232,88H216V64a16,16,0,0,0-16-16H48A16,16,0,0,0,32,64V88H16a8,8,0,0,0,0,16H32v24a16,16,0,0,0,16,16H200a16,16,0,0,0,16-16V104h16v50L131.6,182.65A16.07,16.07,0,0,0,120,198v34a8,8,0,0,0,16,0V198l100.4-28.68A16.07,16.07,0,0,0,248,154V104A16,16,0,0,0,232,88Zm-32,40H48V64H200v64Z"></path></svg>`,

          // Boiserie et ferronneries
        `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256"><path d="M248,64H8A8,8,0,0,0,8,80h8V192a8,8,0,0,0,16,0V144H224v48a8,8,0,0,0,16,0V80h8a8,8,0,0,0,0-16ZM32,80h88v48H32Zm192,48H136V80h88ZM96,104a8,8,0,0,1-8,8H64a8,8,0,0,1,0-16H88A8,8,0,0,1,96,104Zm64,0a8,8,0,0,1,8-8h24a8,8,0,0,1,0,16H168A8,8,0,0,1,160,104Z"></path></svg>`
        ];

        return (
          <a
            href={service.href}
            class="service card service-reveal"
            data-services-reveal
            style={`--reveal-delay: ${0.12 * (index + 1)}s;`}
          >
            <span class="service-icon" set:html={icons[index]}></span>
            <h3>{service.title}</h3>
            <p>{service.text}</p>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.74rem;
    font-weight: 700;
    color: #7A5C3E;
  }

  .eyebrow::before {
    content: '';
    width: 28px;
    height: 1px;
    background: rgba(122, 92, 62, 0.42);
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .service {
    padding: 1.4rem;
    background: linear-gradient(180deg, rgba(255,255,255,0.82), rgba(247,243,236,0.72));
    border: 1px solid rgba(255,255,255,0.7);
    position: relative;
    overflow: hidden;
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease,
      border-color 0.35s ease;
  }

  .service::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.22), rgba(255,255,255,0.04) 35%, transparent 65%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .service:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 30px rgba(23,22,20,0.08);
    border-color: rgba(176, 141, 87, 0.28);
  }

  .service:hover::before {
    opacity: 1;
  }

  .service-icon {
    width: 3rem;
    height: 3rem;
    margin-bottom: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #7A5C3E;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(255,255,255,0.72), rgba(247,243,236,0.46));
    border: 1px solid rgba(122, 92, 62, 0.12);
  }

  .service-icon svg {
    width: 1.35rem;
    height: 1.35rem;
    display: block;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .service:hover .service-icon {
    transform: translateY(-1px) scale(1.02);
    border-color: rgba(176, 141, 87, 0.24);
    background: linear-gradient(180deg, rgba(255,255,255,0.82), rgba(244,238,230,0.62));
    transition:
      transform 0.35s ease,
      border-color 0.35s ease,
      background 0.35s ease;
  }

  .service h3 {
    margin-bottom: 0.75rem;
  }

  .services-reveal-head,
  .service-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.85s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0s);
    will-change: opacity, transform;
  }

  .services-reveal-head.is-visible,
  .service-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .services-reveal-head {
    --reveal-delay: 0s;
  }

  @media (prefers-reduced-motion: reduce) {
    .services-reveal-head,
    .service-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .service {
      transition: none;
    }

    .service:hover {
      transform: none;
      box-shadow: none;
    }

    .service::before {
      display: none;
    }
  }

  @media (max-width: 900px) {
    .service-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const servicesSection = document.querySelector('[data-services-section]');

  if (servicesSection && typeof window !== 'undefined') {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const items = servicesSection.querySelectorAll('[data-services-reveal]');

    if (prefersReducedMotion) {
      items.forEach((item) => item.classList.add('is-visible'));
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              setTimeout(() => {
                items.forEach((item) => item.classList.add('is-visible'));
              }, 180);

              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.18,
          rootMargin: '0px 0px -8% 0px',
        }
      );

      observer.observe(servicesSection);
    }
  }
</script>
