---
const services = [
  {
    title: 'Nettoyage intérieur et extérieur',
    text: 'Nettoyage de surfaces intérieures, façades et annexes pour maintenir des espaces propres et fonctionnels.',
  },
  {
    title: 'Nettoyage technique et sols',
    text: 'Traitement de surfaces, sols et zones sollicitées avec des méthodes adaptées aux contraintes d’usage.',
  },
  {
    title: 'Entretien boiseries et éléments métalliques',
    text: 'Nettoyage, entretien et remise en état d’éléments bois et métal pour prolonger leur durabilité.',
  },
];
---
<section class="section" id="expertise">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">Expertise</span>
      <h2>Une présence sobre, précise et pensée pour des chantiers de haut niveau.</h2>
      <p class="lead">
        La direction artistique s’éloigne des codes trop colorés pour privilégier une esthétique architecturale : matières minérales,
        typographies élégantes, détails discrets et hiérarchie claire.
      </p>
    </div>

    <div class="service-grid">
      {services.map((service, index) => (
        <article class="service card">
          <span class="service-index">0{index + 1}</span>
          <h3>{service.title}</h3>
          <p>{service.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .service {
    padding: 1.4rem;
    background: linear-gradient(180deg, rgba(255,255,255,0.82), rgba(247,243,236,0.72));
    border: 1px solid rgba(255,255,255,0.7);
    position: relative;
    overflow: hidden;
  }
  .service-index {
    display: inline-flex;
    margin-bottom: 1rem;
    color: var(--accent);
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2rem;
    line-height: 1;
  }
  .service h3 {
    margin-bottom: 0.75rem;
  }
  @media (max-width: 900px) {
    .service-grid { grid-template-columns: 1fr; }
  }
</style>
